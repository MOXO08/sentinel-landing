---
import SovereignLayout from '../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../components/react/sentinel/sovereign-footer';

export const prerender = false;

const { slug } = Astro.params;
const env = (Astro.locals as any).runtime?.env;

const categories = ['openai', 'langchain', 'rag', 'agents', 'transformers', 'vector-db', 'ml-pipeline'];
const insightViews = ['highest-score', 'highest-risk', 'recently-scanned'];

const isCategory = categories.includes(slug || '');
const isInsight = insightViews.includes(slug || '');

let report = null;
let categoryReports: any[] = [];
let mode = 'report';
let viewTitle = "";

try {
  if (env?.DB) {
    if (isCategory || isInsight) {
      mode = 'list';
      let query = "SELECT * FROM discovery_audits WHERE is_public = 1";
      if (isCategory) {
        query += ` AND categories LIKE ?`;
        const result = await env.DB.prepare(query).bind(`%"${slug}"%`).all();
        categoryReports = result.results || [];
        viewTitle = `${slug?.charAt(0).toUpperCase()}${slug?.slice(1)} AI Compliance Index`;
      } else if (slug === 'highest-score') {
        query += " ORDER BY audit_score DESC LIMIT 50";
        const result = await env.DB.prepare(query).all();
        categoryReports = result.results || [];
        viewTitle = "Top Scored AI Repositories";
      } else if (slug === 'highest-risk') {
        query += " ORDER BY CASE risk_level WHEN 'High' THEN 1 WHEN 'Medium' THEN 2 ELSE 3 END ASC, audit_score ASC LIMIT 50";
        const result = await env.DB.prepare(query).all();
        categoryReports = result.results || [];
        viewTitle = "High Risk AI Repositories";
      } else if (slug === 'recently-scanned') {
        query += " ORDER BY scan_timestamp DESC LIMIT 50";
        const result = await env.DB.prepare(query).all();
        categoryReports = result.results || [];
        viewTitle = "Recently Scanned AI Repositories";
      }
    } else {
      report = await env.DB.prepare(`
        SELECT * FROM discovery_audits 
        WHERE slug = ? AND is_public = 1
      `).bind(slug).first();
    }
  }
} catch (e) {
  console.error("Discovery Fetch Error:", e);
}

if (!report && categoryReports.length === 0) {
  return Astro.redirect('/404');
}

// Publishing Guardrail: Hide reports with score 0 or missing summary
const isReportPublishable = mode === 'report' && 
  report && 
  report.audit_score > 0 && 
  report.summary_text && 
  report.summary_text.length > 20;

if (mode === 'report' && !isReportPublishable) {
  return Astro.redirect('/404');
}

// SEO Guard: Add noindex if confidence is low or score is borderline
const shouldNoIndex = mode === 'report' && 
  (report.confidence_level === 'Low' || report.audit_score < 40);

const title = mode === 'report' 
  ? `AI Compliance Technical Report: ${report.repo_name} | Sentinel Intelligence`
  : `${viewTitle} | Sentinel AI Compliance Index`;

const description = mode === 'report'
  ? `Automated technical assessment of ${report.repo_name} for AI Act compliance patterns, technical transparency, and risk management signals.`
  : `Explore AI repositories in the ${viewTitle} category. Detailed technical compliance audits and risk profiles.`;

// Robust JSON parsing
const parseJSON = (data: any) => {
  if (!data) return [];
  try {
    return typeof data === 'string' ? JSON.parse(data) : data;
  } catch (e) {
    return [];
  }
};

const gaps = mode === 'report' ? parseJSON(report.visible_gaps) : [];
const rules = mode === 'report' ? parseJSON(report.rules_failed) : [];

const canonicalUrl = `https://gettingsentinel.com/ai-compliance/${slug}`;
---

<SovereignLayout title={title} description={description}>
  {shouldNoIndex && <meta name="robots" content="noindex" slot="head" />}
  <SovereignHeader client:idle />
  
  <main class="bg-[#F4F1EA] pt-32 pb-24 px-6 font-sans">
    <div class="max-w-6xl mx-auto">
      
      {mode === 'report' ? (
        <div class="max-w-4xl mx-auto">
          <!-- Safe Disclaimer -->
          <div class="mb-12 p-6 bg-white border border-[#e2e8f0] rounded-2xl text-[11px] text-[#64748b] font-mono leading-relaxed shadow-sm">
            <div class="flex items-center gap-2 mb-3">
               <div class="w-1.5 h-1.5 rounded-full bg-[#3b82f6] animate-pulse"></div>
               <strong class="text-[#0f172a] uppercase tracking-tighter">Automated Technical Assessment</strong> 
            </div>
            This page presents an automated technical analysis generated by Sentinel's discovery engine based on publicly accessible repository evidence (cloned source code, manifests, and documentation). 
            This assessment is provided for informational and engineering review purposes <strong>only</strong> and does not constitute legal advice, a legal determination, or an official certification of compliance.
            Discovered signals may not reflect private internal compliance artifacts or secondary governance controls.
          </div>

          <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-6">
            <div>
              <nav class="flex mb-4 text-[10px] font-mono uppercase tracking-widest text-[#94a3b8] gap-2">
                <a href="/ai-compliance" class="hover:text-[#0f172a]">Intelligence Layer</a>
                <span>/</span>
                <span class="text-[#0f172a] font-bold">{report.repo_name}</span>
              </nav>
              <h1 class="text-4xl font-black text-[#0f172a] mb-4 tracking-tight leading-none uppercase italic">
                {report.repo_name}
              </h1>
              <div class="flex flex-wrap gap-3">
                <span class="px-3 py-1 bg-white border border-[#e2e8f0] rounded-full text-[10px] font-bold text-[#64748b] uppercase tracking-widest">
                   {report.language || 'unknown'}
                </span>
                <span class="px-3 py-1 bg-white border border-[#e2e8f0] rounded-full text-[10px] font-bold text-[#64748b] uppercase tracking-widest">
                   {report.stars} Stars
                </span>
                <a href={report.repo_url} target="_blank" class="px-3 py-1 bg-[#0f172a] text-white rounded-full text-[10px] font-bold uppercase tracking-widest flex items-center gap-1 hover:bg-[#3b82f6] transition-all">
                   View Source <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </div>
            </div>
            
            <div class="flex flex-col items-end">
              <div class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-widest mb-2">Sync Status</div>
              <div class="px-4 py-2 bg-[#10b981]/10 border border-[#10b981]/20 rounded-lg">
                 <span class="text-[#059669] text-xs font-bold font-mono tracking-tighter uppercase whitespace-nowrap">
                   ● Verified Scan Ref: 0x{report.id?.toString(16).padStart(4, '0')}
                 </span>
              </div>
            </div>
          </div>

          <div class="grid md:grid-cols-3 gap-8 mb-16">
            <div class="bg-white p-8 rounded-2xl border border-[#e2e8f0] shadow-sm">
              <p class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-[0.2em] mb-4">Audit Score</p>
              <div class="text-5xl font-black text-[#0f172a]">{report.audit_score}<span class="text-lg opacity-30">/100</span></div>
              <p class="mt-4 text-[9px] font-mono text-[#94a3b8] uppercase tracking-wider">Deterministic Weighting</p>
            </div>
            <div class="bg-white p-8 rounded-2xl border border-[#e2e8f0] shadow-sm">
              <p class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-[0.2em] mb-4">Risk Profile</p>
              <div class={`text-3xl font-black uppercase tracking-tighter ${report.risk_level === 'Low' ? 'text-[#059669]' : (report.risk_level === 'Medium' ? 'text-[#d97706]' : 'text-[#dc2626]')}`}>
                {report.risk_level} Risk
              </div>
              <p class="mt-4 text-[9px] font-mono text-[#94a3b8] uppercase tracking-wider">Signal Complexity</p>
            </div>
            <div class="bg-white p-8 rounded-2xl border border-[#e2e8f0] shadow-sm">
              <p class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-[0.2em] mb-4">Confidence</p>
              <div class="text-3xl font-black text-[#0f172a] uppercase tracking-tighter">
                {report.confidence_level || 'Medium'}
              </div>
              <p class="mt-4 text-[9px] font-mono text-[#94a3b8] uppercase tracking-wider">Evidence Depth</p>
            </div>
          </div>

          <div class="space-y-12">
            <section>
              <h2 class="text-[10px] font-mono font-bold text-[#0f172a] uppercase tracking-[0.3em] mb-6 flex items-center gap-3">
                Assessment Summary
                <div class="flex-1 h-px bg-[#0f172a]/10"></div>
              </h2>
              <div class="bg-white p-10 rounded-3xl border border-[#e2e8f0] shadow-sm">
                <p class="text-xl leading-relaxed text-[#1e293b] font-serif italic mb-8">
                  "{report.summary_text}"
                </p>
                <div class="flex items-center gap-2 text-[10px] font-mono text-[#64748b]">
                  <span class="uppercase font-bold text-[#0f172a]">Detected Stack:</span>
                  <span class="bg-[#f1f5f9] px-2 py-0.5 rounded text-[#0f172a]">{report.detected_ai_stack}</span>
                </div>
              </div>
            </section>

            <div class="grid md:grid-cols-2 gap-8">
               <section>
                  <h2 class="text-[10px] font-mono font-bold text-[#dc2626] uppercase tracking-[0.3em] mb-6">Critical Gaps</h2>
                  <div class="space-y-3">
                     {gaps.map((gap: string) => (
                        <div class="bg-white p-4 rounded-xl border border-[#e2e8f0] flex items-start gap-3 shadow-sm">
                           <svg class="w-4 h-4 text-[#ef4444] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                           <p class="text-xs font-medium text-[#475569]">{gap}</p>
                        </div>
                     ))}
                     {gaps.length === 0 && (
                        <div class="p-6 text-center text-[#94a3b8] italic bg-white rounded-xl border border-dashed border-[#e2e8f0] text-xs">
                           No significant technical gaps identified.
                        </div>
                     )}
                  </div>
               </section>

               <section>
                  <h2 class="text-[10px] font-mono font-bold text-[#0f172a] uppercase tracking-[0.3em] mb-6">Regulatory Artifacts</h2>
                  <div class="flex flex-wrap gap-2">
                     {rules.map((rule: string) => (
                        <span class="px-3 py-1.5 bg-[#1e293b]/5 text-[#1e293b] text-[10px] font-bold rounded-lg border border-[#1e293b]/10 uppercase font-mono">
                           {rule.replace(/_/g, ' ')}
                        </span>
                     ))}
                     {rules.length === 0 && (
                        <div class="p-6 w-full text-center text-[#94a3b8] italic bg-white rounded-xl border border-dashed border-[#e2e8f0] text-xs font-mono">
                           Evidence manifest: empty
                        </div>
                     )}
                  </div>
               </section>
            </div>

            <section class="bg-white p-10 rounded-3xl border border-[#e2e8f0] shadow-sm">
               <h2 class="text-sm font-black text-[#0f172a] uppercase tracking-widest mb-6">Methodology & Verification</h2>
               <div class="prose prose-slate prose-sm text-[#64748b]">
                  <p>
                     This assessment was performed using the <strong>Sentinel Discovery Engine (v1.0)</strong>. Our automated pipeline executes the following steps:
                  </p>
                  <ul class="text-xs space-y-2">
                     <li><strong>Static Analysis</strong>: Clones the repository and audits source files for AI-specific dependencies and patterns.</li>
                     <li><strong>Manifest Extraction</strong>: Detects standardized compliance signatures and deterministic evidence of risk management.</li>
                     <li><strong>Heuristic Scoring</strong>: Aggregates findings into a quantitative trust score focused on technical transparency.</li>
                  </ul>
               </div>
            </section>
          </div>
        </div>
      ) : (
        <!-- List Mode (Category/Insight) -->
        <div>
          <header class="mb-16 border-b border-[#0f172a]/10 pb-12">
            <nav class="flex mb-4 text-[10px] font-mono uppercase tracking-widest text-[#94a3b8] gap-2">
              <a href="/ai-compliance" class="hover:text-[#0f172a]">Intelligence Layer</a>
              <span>/</span>
              <span class="text-[#0f172a] font-bold">Category Exploration</span>
            </nav>
            <h1 class="text-5xl font-black text-[#0f172a] mb-6 tracking-tight uppercase italic">{viewTitle}</h1>
            <p class="text-xl text-[#1e293b] max-w-2xl leading-relaxed">
              Filtered analysis of AI repositories matching the detected stack or compliance profile.
            </p>
          </header>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {categoryReports.map((report) => (
              <a href={`/ai-compliance/${report.slug}`} class="group bg-white p-8 rounded-3xl border border-[#e2e8f0] shadow-sm hover:shadow-xl hover:border-[#3b82f6] transition-all flex flex-col">
                <div class="flex justify-between items-start mb-4">
                  <h2 class="text-xl font-bold text-[#0f172a] group-hover:text-[#3b82f6] line-clamp-1">{report.repo_name}</h2>
                  <span class="text-[10px] font-mono text-[#94a3b8] flex-shrink-0 ml-4">{report.stars} ⭐</span>
                </div>

                <div class="mb-4">
                   <span class="text-[9px] font-mono bg-[#f8fafc] px-2 py-0.5 border border-[#f1f5f9] rounded text-[#64748b] uppercase">{report.detected_ai_stack}</span>
                </div>
                
                <p class="text-sm text-[#64748b] line-clamp-3 mb-6 flex-1">
                   {report.summary_text}
                </p>

                <div class="flex items-center gap-4 mb-8">
                  <div class="text-2xl font-black text-[#0f172a]">{report.audit_score}<span class="text-xs opacity-30">/100</span></div>
                  <div class={`px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest ${report.risk_level === 'Low' ? 'bg-[#10b981]/10 text-[#059669]' : (report.risk_level === 'Medium' ? 'bg-[#f59e0b]/10 text-[#d97706]' : 'bg-[#ef4444]/10 text-[#dc2626]')}`}>
                    {report.risk_level} Risk
                  </div>
                </div>

                <div class="pt-6 border-t border-[#f1f5f9] flex justify-between items-center">
                  <span class="text-[10px] font-mono text-[#94a3b8]">{new Date(report.scan_timestamp).toLocaleDateString()}</span>
                  <span class="text-xs font-bold text-[#3b82f6] opacity-0 group-hover:opacity-100 transition-opacity">Full Analysis &rarr;</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Footer Info -->
      <div class="mt-24 pt-12 border-t border-[#e2e8f0] flex flex-col items-center text-center">
        <p class="text-[9px] font-mono text-[#94a3b8] uppercase tracking-[0.4em] mb-4 underline decoration-[#3b82f6]/30">Sentinel Technical Audit Feed</p>
        <p class="text-xs text-[#64748b] font-mono">
          Last Indexed: {mode === 'report' ? new Date(report.scan_timestamp).toISOString() : new Date().toISOString()}
        </p>
      </div>

    </div>
  </main>

  <SovereignFooter client:visible />
</SovereignLayout>

