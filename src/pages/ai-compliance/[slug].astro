---
import SovereignLayout from '../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../components/react/sentinel/sovereign-footer';

export const prerender = false;

const { slug } = Astro.params;
const env = (Astro.locals as any).runtime?.env;

// Legacy Slug Redirects
const categoryMap: Record<string, string> = {
    'openai': 'openai',
    'langchain': 'langchain',
    'rag': 'rag',
    'agents': 'agents',
    'transformers': 'transformers',
    'vector-db': 'vector-db',
    'ml-pipeline': 'ml-pipeline'
};

const viewMap: Record<string, string> = {
    'highest-score': 'top-scores',
    'top-scores': 'top-scores',
    'highest-risk': 'high-risk',
    'high-risk': 'high-risk',
    'recently-scanned': 'recent',
    'recent': 'recent'
};

if (slug && categoryMap[slug]) {
    return Astro.redirect(`/ai-compliance?category=${categoryMap[slug]}`);
}

if (slug && viewMap[slug]) {
    return Astro.redirect(`/ai-compliance?view=${viewMap[slug]}`);
}

let report = null;

try {
  if (env?.DB) {
    report = await env.DB.prepare(`
      SELECT *, rules_passed, detected_artifacts, detected_signals, missing_signals FROM discovery_audits 
      WHERE slug = ? AND is_public = 1
    `).bind(slug).first();
  }
} catch (e) {
  console.error("Discovery Fetch Error:", e);
}

if (!report) {
  return Astro.redirect('/404');
}

// Publishing Guardrail: Hide reports with zero technical evidence or generic fallout
const hasPowerEvidence = 
  report.detected_artifacts?.includes('AI-MANIFEST.json') || 
  report.detected_artifacts?.includes('model-card.md') || 
  report.detected_artifacts?.includes('.sentinel') ||
  report.detected_artifacts?.includes('privacy-policy.md') ||
  report.detected_signals?.includes('Art. ') ||
  report.detected_signals?.includes('Found');

const isReportPublishable = 
  report && 
  (hasPowerEvidence || report.risk_level === 'High') &&
  !report.summary_text?.includes("Public technical evidence is limited") &&
  report.audit_score > 0 && 
  report.summary_text && 
  report.summary_text.length > 20;

if (!isReportPublishable) {
  return Astro.redirect('/404');
}

// SEO Guard: Add noindex if confidence is low or score is borderline
const shouldNoIndex = report.confidence_level === 'Low' || report.audit_score < 40;

const title = `AI Compliance Technical Report: ${report.repo_name} | Sentinel Intelligence`;
const description = `Automated technical assessment of ${report.repo_name} for AI Act compliance patterns, technical transparency, and risk management signals.`;

// Robust JSON parsing
const parseJSON = (data: any) => {
  if (!data) return [];
  try {
    return typeof data === 'string' ? JSON.parse(data) : data;
  } catch (e) {
    return [];
  }
};

const gaps = parseJSON(report.visible_gaps);
const rules = parseJSON(report.rules_failed);
const passed = parseJSON(report.rules_passed);
const artifacts = parseJSON(report.detected_artifacts);

const detectedSignalsTable = parseJSON(report.detected_signals);
const missingSignalsTable = parseJSON(report.missing_signals);

// Signal Logic (Standardized Taxonomy - No Articles)
function getSignalCode() {
    // 1. Prioritize Missing Signals (Critical Gaps)
    if (missingSignalsTable.some((s: string) => s.includes('Art. 10'))) return "DATA-PROVENANCE-MISSING";
    if (missingSignalsTable.some((s: string) => s.includes('Art. 13'))) return "DOC-MODEL-MISSING";
    if (missingSignalsTable.some((s: string) => s.includes('Art. 9'))) return "RISK-ASSESSMENT-MISSING";
    if (missingSignalsTable.some((s: string) => s.includes('GDPR'))) return "PRIVACY-POLICY-MISSING";

    // 2. Identify Found Signals
    if (detectedSignalsTable.length > 0) return "TECHNICAL-SIGNALS-FOUND";

    // 3. Fallback to heuristic mapping for legacy rows (only if new fields are empty)
    const allSignals = [...gaps.map((g: string) => g.toLowerCase()), ...rules.map((r: string) => r.toLowerCase())];
    
    if (allSignals.some(s => s.includes('dataset') || s.includes('provenance') || s.includes('art-10'))) return "DATA-PROVENANCE-MISSING";
    if (allSignals.some(s => s.includes('model card') || s.includes('art-13'))) return "DOC-MODEL-MISSING";
    if (allSignals.some(s => s.includes('risk assessment') || s.includes('art-9'))) return "RISK-ASSESSMENT-MISSING";
    if (allSignals.some(s => s.includes('privacy'))) return "PRIVACY-POLICY-MISSING";

    return null;
}

function getRegulatoryRelevance() {
    const code = getSignalCode();
    if (!code) return "Global AI Governance Framework Alignment";
    if (code.includes('DATA-PROVENANCE') || code.includes('DOC-GENERAL')) return "Article 10";
    if (code.includes('DOC-MODEL')) return "Article 13";
    if (code.includes('RISK-ASSESSMENT')) return "Article 9";
    return "Baseline Compliance Monitoring";
}

function getConcreteFinding() {
    const summary = report.summary_text || "";

    // 1. First Missing Signal (Highest Priority for Transparency)
    if (missingSignalsTable.length > 0) {
        return `Missing critical artifact: ${missingSignalsTable[0].split(' (')[0]}`;
    }

    // 2. First Detected Signal (If no missing)
    if (detectedSignalsTable.length > 0) {
        return `Technical evidence detected for ${detectedSignalsTable[0].split(' (')[0]}`;
    }

    // 3. Persisted Summary (if non-generic/short)
    if (summary && summary.length > 20 && !summary.includes("Automated technical analysis indicates")) {
        return summary;
    }

    // 4. Legacy Fallback (Last Resort)
    return "Public technical evidence is limited for this repository.";
}

// Found Signals (Strict Artifact-Backed)
const foundSignals = detectedSignalsTable.length > 0 
    ? detectedSignalsTable.map((s: string) => s.split(' (')[0])
    : [];

if (foundSignals.length === 0) {
    if (passed.some((p: string) => p.includes('license')) || artifacts.includes('LICENSE')) foundSignals.push('LICENSE');
    if (passed.some((p: string) => p.includes('ci_integration')) || artifacts.some((a: string) => a.includes('workflows'))) foundSignals.push('CI workflow');
    if (artifacts.some((a: string) => a.toLowerCase().endsWith('.sarif'))) foundSignals.push('SARIF');
    if (passed.some((p: string) => p.includes('model_card')) || artifacts.includes('model-card.md')) foundSignals.push('Model Card');
}

// Missing Signals (Strict Derivation)
const finalMissing = missingSignalsTable.length > 0 
    ? missingSignalsTable.map((s: string) => s.split(' (')[0]).slice(0, 3)
    : [];

if (finalMissing.length === 0) {
    const legacyMissing = [];
    if (gaps.some((g: string) => g.toLowerCase().includes('model'))) legacyMissing.push('Model Card / Technical File (Art. 13)');
    if (gaps.some((g: string) => g.toLowerCase().includes('data'))) legacyMissing.push('Dataset Provenance / Training Logs (Art. 10)');
    finalMissing.push(...legacyMissing.slice(0, 3));
}

// Multi-tier Risk Theme Engine
function getRiskTheme(score: number) {
    if (score === 100) return { label: 'Sovereign', rating: 'AAA', color: 'text-[#059669]', bg: 'bg-[#059669]/5', border: 'border-[#059669]/20' };
    if (score >= 90) return { label: 'High Integrity', rating: 'AA', color: 'text-[#10b981]', bg: 'bg-[#10b981]/5', border: 'border-[#10b981]/20' };
    if (score >= 75) return { label: 'Compliant', rating: 'A', color: 'text-[#84cc16]', bg: 'bg-[#84cc16]/5', border: 'border-[#84cc16]/20' };
    if (score >= 50) return { label: 'Elevated Risk', rating: 'B', color: 'text-[#f59e0b]', bg: 'bg-[#f59e0b]/5', border: 'border-[#f59e0b]/20' };
    if (score >= 25) return { label: 'High Risk', rating: 'C', color: 'text-[#f97316]', bg: 'bg-[#f97316]/5', border: 'border-[#f97316]/20' };
    return { label: 'Critical', rating: 'F', color: 'text-[#dc2626]', bg: 'bg-[#dc2626]/5', border: 'border-[#dc2626]/20' };
}

const theme = getRiskTheme(report.audit_score);
---

<SovereignLayout title={title} description={description}>
  {shouldNoIndex && <meta name="robots" content="noindex" slot="head" />}
  <SovereignHeader client:idle />
  
  <main class="bg-[#F4F1EA] pt-32 pb-24 px-6 font-sans">
    <div class="max-w-6xl mx-auto">
      
        <div class="max-w-4xl mx-auto text-[#0f172a]">
          {report.risk_level === 'High' && !hasPowerEvidence && (
            <div class="mb-12 p-6 bg-[#dc2626]/5 border border-[#dc2626]/20 rounded-2xl flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#dc2626]/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#dc2626]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 9v4m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 17c-.77 1.333.192 3 1.732 3z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-black uppercase tracking-tight text-[#dc2626] mb-1">Verifiable Evidence Missing</h3>
                <p class="text-xs text-[#dc2626]/80 leading-relaxed font-medium">
                  This repository has been flagged as <strong>High Risk</strong> due to a lack of public AI compliance artifacts (e.g., AI-MANIFEST.json, Model Cards, or explicit Article 13 disclosures). The current score reflects a critical deficiency in technical transparency.
                </p>
              </div>
            </div>
          )}
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-6">
            <div>
              <nav class="flex mb-6 text-[10px] font-mono uppercase tracking-widest text-[#94a3b8] gap-2">
                <a href="/ai-compliance" class="hover:text-[#0f172a]">Intelligence Hub</a>
                <span>/</span>
                <span class="text-[#0f172a] font-bold">{report.repo_name}</span>
              </nav>
              <h1 class="text-4xl font-black mb-4 tracking-tighter uppercase italic">
                {report.repo_name}
              </h1>
              <div class="flex flex-wrap gap-2">
                <span class="px-2 py-1 bg-white border border-[#0f172a]/10 rounded text-[9px] font-bold text-[#64748b] uppercase tracking-widest">
                   {report.language || 'unknown'}
                </span>
                <span class="px-2 py-1 bg-white border border-[#0f172a]/10 rounded text-[9px] font-bold text-[#64748b] uppercase tracking-widest">
                   {report.stars.toLocaleString()} Stars
                </span>
                <span class={`px-2 py-1 border border-[#0f172a]/10 rounded text-[9px] font-black uppercase tracking-widest ${theme.color} ${theme.bg}`}>
                    {theme.label} — {theme.rating}
                </span>
              </div>
            </div>
            
            <div class="flex flex-col items-end">
                <div class="text-[3xl] font-black leading-none">{report.audit_score}<span class="text-[10px] opacity-30">/100</span></div>
                <div class="text-[9px] font-mono font-bold text-[#94a3b8] uppercase tracking-widest mt-1">Audit Score</div>
            </div>
          </div>

          <!-- Summary Block -->
          <section class="bg-white border border-[#0f172a]/10 rounded-2xl overflow-hidden shadow-sm mb-12">
            <div class="bg-[#0f172a] px-8 py-4 flex items-center justify-between">
                <h2 class="text-[10px] font-black text-white uppercase tracking-[0.2em]">Technical Summary</h2>
                <div class="text-[9px] font-mono text-white/50 uppercase">Scan Ref: 0x{report.id?.toString(16).padStart(4, '0')}</div>
            </div>
            
            <div 
              class="p-8 grid md:grid-cols-[1fr_1px_1fr] gap-8 items-start"
              data-ai-generated="true"
              data-ai-system="sentinel-engine"
              data-ai-disclosure="article-52"
            >
                <div class="col-span-full mb-2 pb-4 border-b border-[#0f172a]/5 flex items-center gap-2">
                    <div class="w-1.5 h-1.5 rounded-full bg-[#f59e0b] animate-pulse"></div>
                    <span class="text-[9px] font-mono font-bold text-[#f59e0b] uppercase tracking-widest">
                        AI-assisted regulatory mapping by Sentinel Engine (EU AI Act Art. 52 Transparency Active)
                    </span>
                </div>
                <div class="space-y-6">
                    <div>
                        <h3 class="text-[9px] font-mono font-bold text-[#94a3b8] uppercase tracking-widest mb-2">Primary Finding</h3>
                        <p class="text-lg font-bold italic leading-tight text-[#0f172a]">"{getConcreteFinding()}"</p>
                    </div>
                    <div>
                        <h3 class="text-[9px] font-mono font-bold text-[#94a3b8] uppercase tracking-widest mb-2">Regulatory Relevance</h3>
                        <p class="text-xs font-medium text-[#475569]">{getRegulatoryRelevance()}</p>
                    </div>
                </div>
                
                <div class="hidden md:block w-px h-full bg-[#0f172a]/5"></div>

                <div class="space-y-6">
                    <div>
                        <h3 class="text-[9px] font-mono font-bold text-[#94a3b8] uppercase tracking-widest mb-2">Detected Signals</h3>
                        <ul class="space-y-1.5">
                            {foundSignals.map((sign: string) => (
                                <li class="text-[10px] text-[#059669] font-bold flex items-center gap-2">
                                    <div class="w-1 h-1 rounded-full bg-[#059669]"></div>
                                    {sign}
                                </li>
                            ))}
                            <li class="text-[10px] text-[#0f172a] font-mono bg-[#F4F1EA] px-2 py-0.5 rounded border border-[#0f172a]/5 mt-2">
                                {report.detected_ai_stack}
                            </li>
                        </ul>
                    </div>
                    <div>
                        <h3 class="text-[9px] font-mono font-bold text-[#94a3b8] uppercase tracking-widest mb-2">Missing Signals</h3>
                        <ul class="space-y-1.5">
                            {finalMissing.map((gap: string) => (
                                <li class="text-[10px] text-[#ef4444] font-bold flex items-center gap-2">
                                    <div class="w-1 h-1 rounded-full bg-[#ef4444]"></div>
                                    {gap}
                                </li>
                            ))}
                            {finalMissing.length === 0 && <li class="text-[10px] text-[#64748b] italic">No critical technical gaps identified.</li>}
                        </ul>
                    </div>
                </div>
            </div>

            <div class="px-8 py-4 bg-[#f8fafc] border-t border-[#0f172a]/5 flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div class="text-[9px] text-[#64748b] font-mono uppercase tracking-tight">
                    <strong>Disclaimer:</strong> Automated technical assessment only. Not a legal determination.
                </div>
                <a href={report.repo_url} target="_blank" class="px-4 py-2 bg-[#0f172a] text-white rounded text-[9px] font-black uppercase tracking-widest flex items-center gap-2 hover:bg-[#3b82f6] transition-all">
                   View Source Code <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            </div>
          </section>

          <div class="grid md:grid-cols-2 gap-8 mb-16">
            <section class="bg-white p-10 rounded-3xl border border-[#0f172a]/5 shadow-sm">
                <h3 class="text-[10px] font-mono font-bold text-[#0f172a] uppercase tracking-[0.3em] mb-6">Technical Summary</h3>
                <p class="text-sm leading-relaxed text-[#475569] font-serif italic">
                    "{report.summary_text}"
                </p>
            </section>

            <section class="bg-white p-10 rounded-3xl border border-[#0f172a]/5 shadow-sm">
                <h3 class="text-[10px] font-mono font-bold text-[#0f172a] uppercase tracking-[0.3em] mb-6 flex items-center gap-2">
                    Evidence Manifest
                    <span class="px-1.5 py-0.5 bg-[#0f172a] text-white text-[8px] rounded uppercase">{rules.length} Items</span>
                </h3>
                <div class="flex flex-wrap gap-2">
                    {rules.map((rule: string) => (
                        <span class="px-2 py-1 bg-[#f1f5f9] text-[#64748b] text-[9px] font-bold rounded border border-[#0f172a]/5 uppercase font-mono">
                            {rule.replace(/_/g, ' ')}
                        </span>
                    ))}
                    {rules.length === 0 && <div class="text-[10px] text-[#94a3b8] italic">No deterministic artifacts identified.</div>}
                </div>
            </section>
          </div>

          <section class="bg-[#0f172a] p-10 rounded-3xl text-white/80 shadow-xl overflow-hidden relative">
             <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>
             <h3 class="text-[10px] font-black text-white uppercase tracking-[0.3em] mb-6">Methodology</h3>
             <div class="grid md:grid-cols-2 gap-10 relative z-10">
                <div class="space-y-4">
                    <p class="text-xs leading-relaxed">
                        This assessment was performed via <strong>Sentinel Discovery Engine (v1.0)</strong>, executing static analysis on public repository branches.
                    </p>
                    <ul class="text-[10px] font-mono space-y-2 opacity-60">
                        <li>● Deterministic manifest checking</li>
                        <li>● Dependency cluster analysis</li>
                        <li>● Documentation entropy calculation</li>
                    </ul>
                </div>
                <div class="bg-white/5 p-6 rounded-2xl border border-white/10">
                    <p class="text-[10px] leading-relaxed italic mb-4">
                        "The presence of technical artifacts indicates a baseline of transparency, but does not guarantee total compliance with internal governance policies."
                    </p>
                    <div class="text-[9px] font-bold uppercase tracking-widest text-[#3b82f6]">Sentinel Compliance Heuristics</div>
                </div>
             </div>
          </section>
        </div>

      <!-- Footer Info -->
      <div class="mt-24 pt-12 border-t border-[#0f172a]/5 flex flex-col items-center text-center">
        <p class="text-[9px] font-mono text-[#94a3b8] uppercase tracking-[0.4em] mb-4">Public Intelligence Layer // Index v1.02</p>
        <p class="text-[9px] text-[#64748b] font-mono uppercase">
          Last Verified: {new Date(report.scan_timestamp).toISOString()}
        </p>
      </div>

    </div>
  </main>

  <SovereignFooter client:visible />
</SovereignLayout>

