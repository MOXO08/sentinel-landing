---
import SovereignLayout from '../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../components/react/sentinel/sovereign-footer';

export const prerender = false;

const { slug } = Astro.params;
const env = (Astro.locals as any).runtime?.env;

let report = null;

try {
  if (env?.DB) {
    report = await env.DB.prepare(`
      SELECT * FROM discovery_audits 
      WHERE slug = ? AND is_public = 1
    `).bind(slug).first();
  }
} catch (e) {
  console.error("Report Fetch Error:", e);
}

if (!report) {
  return Astro.redirect('/404');
}

const title = `AI Compliance Technical Report for ${report.repo_name} | Sentinel`;
const description = `Automated technical assessment of ${report.repo_name} for AI Act compliance patterns and technical transparency.`;
const gaps = JSON.parse(report.visible_gaps || '[]');
const rules = JSON.parse(report.rules_failed || '[]');

const canonicalUrl = `https://gettingsentinel.com/ai-compliance/${slug}`;
---

<SovereignLayout title={title}>
  <SovereignHeader client:idle />
  
  <main class="bg-[#F4F1EA] pt-32 pb-24 px-6">
    <div class="max-w-4xl mx-auto">
      
      <!-- Safe Disclaimer -->
      <div class="mb-12 p-4 bg-[#0f172a]/5 border border-[#0f172a]/10 rounded-xl text-[11px] text-[#64748b] font-mono leading-relaxed">
        <strong class="text-[#0f172a] uppercase tracking-tighter mr-2">Technical Disclaimer:</strong> 
        This page presents an automated technical analysis generated by Sentinel based on publicly accessible repository data. 
        It is provided for informational and engineering review purposes only and does not constitute legal advice or a legal determination.
        Automated technical analysis based on publicly available repository data. Informational only. Not legal advice or a legal determination.
      </div>

      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-6">
        <div>
          <h1 class="text-4xl font-black text-[#0f172a] mb-4 tracking-tight leading-none">
            {report.repo_name}
          </h1>
          <div class="flex flex-wrap gap-3">
            <span class="px-3 py-1 bg-white border border-[#e2e8f0] rounded-full text-[10px] font-bold text-[#64748b] uppercase tracking-widest">
              {report.language}
            </span>
            <span class="px-3 py-1 bg-white border border-[#e2e8f0] rounded-full text-[10px] font-bold text-[#64748b] uppercase tracking-widest">
              {report.stars} Stars
            </span>
          </div>
        </div>
        
        <div class="flex flex-col items-end">
          <div class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-widest mb-2">Scan Status</div>
          <div class="px-4 py-2 bg-[#10b981]/10 border border-[#10b981]/20 rounded-lg">
             <span class="text-[#059669] text-xs font-bold font-mono tracking-tighter uppercase whitespace-nowrap">
               ● Technical Verification Active
             </span>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-16">
        <div class="bg-white p-8 rounded-2xl border border-[#e2e8f0] shadow-sm">
          <p class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-[0.2em] mb-4">Audit Score</p>
          <div class="text-5xl font-black text-[#0f172a]">{report.audit_score}<span class="text-lg opacity-30">/100</span></div>
        </div>
        <div class="bg-white p-8 rounded-2xl border border-[#e2e8f0] shadow-sm">
          <p class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-[0.2em] mb-4">Risk Level</p>
          <div class={`text-3xl font-black uppercase tracking-tighter ${report.risk_level === 'Low' ? 'text-[#059669]' : (report.risk_level === 'Medium' ? 'text-[#d97706]' : 'text-[#dc2626]')}`}>
            {report.risk_level}
          </div>
        </div>
        <div class="bg-white p-8 rounded-2xl border border-[#e2e8f0] shadow-sm">
          <p class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-[0.2em] mb-4">Confidence</p>
          <div class="text-3xl font-black text-[#0f172a] uppercase tracking-tighter">
            {report.confidence_level}
          </div>
        </div>
      </div>

      <div class="space-y-12">
        <!-- Assessment Summary -->
        <section>
          <h2 class="text-xl font-bold text-[#0f172a] mb-6 flex items-center gap-3">
            <span class="w-2 h-6 bg-[#3b82f6] rounded-full"></span>
            Technical Assessment Summary
          </h2>
          <div class="bg-white p-8 rounded-3xl border border-[#e2e8f0] shadow-sm prose prose-slate max-w-none">
            <p class="text-lg leading-relaxed text-[#0f172a]/80 italic">
              "{report.summary_text}"
            </p>
            <p class="text-sm text-[#64748b] mt-4">
              Detected Stack: <span class="font-mono bg-[#f1f5f9] px-2 py-0.5 rounded text-[#0f172a]">{report.detected_ai_stack}</span>
            </p>
          </div>
        </section>

        <!-- Findings -->
        <section>
          <h2 class="text-xl font-bold text-[#0f172a] mb-6 flex items-center gap-3">
            <span class="w-2 h-6 bg-[#10b981] rounded-full"></span>
            Automated Findings & Visibility Gaps
          </h2>
          <div class="grid gap-4">
            {gaps.map((gap) => (
              <div class="bg-white p-5 rounded-xl border border-[#e2e8f0] flex items-start gap-4">
                <div class="mt-1 w-5 h-5 rounded-full bg-[#f59e0b]/10 flex items-center justify-center flex-shrink-0">
                  <div class="w-1.5 h-1.5 rounded-full bg-[#d97706]"></div>
                </div>
                <p class="text-sm font-medium text-[#0f172a]">{gap}</p>
              </div>
            ))}
            {gaps.length === 0 && (
              <div class="p-8 text-center text-[#94a3b8] italic bg-white rounded-xl border border-dashed border-[#e2e8f0]">
                No significant visibility gaps identified in the current automated scan.
              </div>
            )}
          </div>
        </section>

        <!-- Improvement Guidance -->
        <section class="bg-[#0f172a] text-white p-10 rounded-3xl shadow-xl shadow-[#0f172a]/20">
          <h2 class="text-2xl font-bold mb-8">Verification & Improvement Guidance</h2>
          <p class="text-white/60 mb-8 max-w-xl">
            This report represents a point-in-time assessment based on public technical signals. Developers can improve their compliance posture and technical alignment by following these steps:
          </p>
          <div class="grid sm:grid-cols-2 gap-6 mb-10">
            <div class="space-y-4">
              <h3 class="text-sm font-bold uppercase tracking-widest text-[#3b82f6]">For Developers</h3>
              <ul class="text-xs space-y-3 opacity-80 list-disc pl-4">
                <li>Integrate [Sentinel GitHub Action](https://github.com/MOXO08/sentinel-scan-action)</li>
                <li>Generate Annex IV Technical Files automatedly</li>
                <li>Define explicit Risk Management technical controls</li>
                <li>Block non-compliant PRs with deterministic gating</li>
              </ul>
            </div>
            <div class="space-y-4">
              <h3 class="text-sm font-bold uppercase tracking-widest text-[#10b981]">Verification Signal</h3>
              <p class="text-[10px] text-white/50 leading-relaxed mb-3">
                Display your technical scan status in your repository README using our deterministic badge.
              </p>
              <div class="p-3 bg-white/5 border border-white/10 rounded-lg">
                <img src="/badge.svg" alt="Sentinel Badge" class="h-5 mb-3" />
                <code class="text-[9px] block bg-black/40 p-2 rounded text-white/70 overflow-x-auto whitespace-nowrap">
                  [![Sentinel AI Act Compliance](https://gettingsentinel.com/badge.svg)](https://gettingsentinel.com)
                </code>
              </div>
            </div>
          </div>
          
          <div class="flex flex-wrap gap-4 pt-8 border-t border-white/10">
            <a href="/docs#cli" class="bg-white text-[#0f172a] px-6 py-3 rounded-full text-xs font-bold hover:bg-[#3b82f6] hover:text-white transition-all">
              Integrate Sentinel Action &rarr;
            </a>
            <a href="/docs#badge" class="bg-white/10 border border-white/20 text-white px-6 py-3 rounded-full text-xs font-bold hover:bg-white/20 transition-all">
              Badge Documentation
            </a>
          </div>
        </section>

      </div>

      <!-- Footer Info -->
      <div class="mt-24 pt-12 border-t border-[#e2e8f0] flex flex-col items-center text-center">
        <p class="text-[10px] font-mono text-[#94a3b8] uppercase tracking-[0.3em] mb-4">Internal Intelligence Layer</p>
        <p class="text-xs text-[#64748b] max-w-md">
          This report is part of Sentinel's mission to map the AI ecosystem and provide deterministic compliance tools for the EU AI Act.
        </p>
      </div>

    </div>
  </main>

  <SovereignFooter client:visible />
</SovereignLayout>
