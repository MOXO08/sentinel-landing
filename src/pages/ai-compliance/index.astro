---
import SovereignLayout from '../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../components/react/sentinel/sovereign-footer';

export const prerender = false;

const env = (Astro.locals as any).runtime?.env;

let reports = [];

// Sorting/Filtering params from URL
const sort = Astro.url.searchParams.get('sort') || 'scan_timestamp';
const order = Astro.url.searchParams.get('order') || 'DESC';
const riskFilter = Astro.url.searchParams.get('risk') || 'all';
const category = Astro.url.searchParams.get('category') || null;
const view = Astro.url.searchParams.get('view') || null;
const search = Astro.url.searchParams.get('search') || '';

const validCols = ['stars', 'audit_score', 'scan_timestamp'];
const safeSort = validCols.includes(sort) ? sort : 'scan_timestamp';
const safeOrder = order === 'ASC' ? 'ASC' : 'DESC';

try {
  if (env?.DB) {
    let query = `
      SELECT repo_name, slug, stars, audit_score, risk_level, scan_timestamp, summary_text, 
             detected_ai_stack, visible_gaps, rules_failed, rules_passed, detected_artifacts,
             detected_signals, missing_signals
      FROM discovery_audits 
      WHERE is_public = 1 
      AND (
        (
          detected_artifacts LIKE '%AI-MANIFEST.json%' OR 
          detected_artifacts LIKE '%model-card.md%' OR 
          detected_artifacts LIKE '%.sentinel%' OR
          detected_artifacts LIKE '%privacy-policy.md%' OR
          detected_signals LIKE '%Art. %' OR
          detected_signals LIKE '%Found%'
        )
        OR (
          risk_level IN ('High Risk', 'Critical') 
          AND (
            detected_signals NOT LIKE '[]' OR
            missing_signals NOT LIKE '[]'
          )
        )
      )
      AND summary_text NOT LIKE '%Public technical evidence is limited%'
      AND audit_score > 0 
      AND LENGTH(summary_text) > 35
    `;
    let params: any[] = [];

    if (search) {
      query += ` AND (repo_name LIKE ? OR detected_ai_stack LIKE ?)`;
      params.push(`%${search}%`, `%${search}%`);
    }

    // Category Filter
    if (category) {
      query += ` AND categories LIKE ?`;
      params.push(`%"${category}"%`);
    }

    // Risk Filter
    if (riskFilter !== 'all') {
      query += ` AND risk_level = ?`;
      params.push(riskFilter);
    }

    // View Overrides Sorting
    let orderByClause = `ORDER BY ${safeSort} ${safeOrder}`;
    
    if (view === 'top-scores') {
        orderByClause = `ORDER BY audit_score DESC`;
    } else if (view === 'high-risk') {
        orderByClause = `ORDER BY CASE risk_level WHEN 'High' THEN 1 WHEN 'Medium' THEN 2 ELSE 3 END ASC, audit_score ASC`;
    } else if (view === 'recent') {
        orderByClause = `ORDER BY scan_timestamp DESC`;
    }

    query += ` ${orderByClause} LIMIT 25`;
    
    const result = await env.DB.prepare(query).bind(...params).all();
    reports = result.results || [];
  }
} catch (e) {
  console.error("Reports Fetch Error:", e);
}

const title = "AI Compliance Technical Reports | Sentinel Intelligence Hub";
const description = "Public technical assessments and compliance patterns for global AI repositories based on the EU AI Act framework.";

// Helper to build stable filter URLs
function getFilterUrl(updates: Record<string, string | null>) {
    const params = new URLSearchParams(Astro.url.searchParams);
    Object.entries(updates).forEach(([k, v]) => {
      if (v === null) {
        params.delete(k);
      } else {
        params.set(k, v);
      }
    });
    return `?${params.toString()}`;
}

// Logic for Primary Signal Code (Standardized Taxonomy - No Articles)
function getSignalCode(report: any) {
    const detected = typeof report.detected_signals === 'string' ? JSON.parse(report.detected_signals) : (report.detected_signals || []);
    const missing = typeof report.missing_signals === 'string' ? JSON.parse(report.missing_signals) : (report.missing_signals || []);
    
    // 1. Prioritize Missing Signals (Critical Gaps)
    if (missing.some((s: string) => s.includes('Art. 10'))) return "DATA-PROVENANCE-MISSING";
    if (missing.some((s: string) => s.includes('Art. 13'))) return "DOC-MODEL-MISSING";
    if (missing.some((s: string) => s.includes('Art. 9'))) return "RISK-ASSESSMENT-MISSING";
    if (missing.some((s: string) => s.includes('GDPR'))) return "PRIVACY-POLICY-MISSING";
    
    // 2. Identify Found Signals
    if (detected.length > 0) return "TECHNICAL-SIGNALS-FOUND";
    
    // 3. Fallback to heuristic mapping for legacy rows (only if new fields are empty)
    const gaps = typeof report.visible_gaps === 'string' ? JSON.parse(report.visible_gaps) : (report.visible_gaps || []);
    const rules = typeof report.rules_failed === 'string' ? JSON.parse(report.rules_failed) : (report.rules_failed || []);
    const allSignals = [...gaps.map((g: string) => g.toLowerCase()), ...rules.map((r: string) => r.toLowerCase())];

    if (allSignals.some(s => s.includes('dataset') || s.includes('provenance') || s.includes('art-10'))) return "DATA-PROVENANCE-MISSING";
    if (allSignals.some(s => s.includes('model card') || s.includes('art-13'))) return "DOC-MODEL-MISSING";
    if (allSignals.some(s => s.includes('risk assessment') || s.includes('art-9'))) return "RISK-ASSESSMENT-MISSING";
    if (allSignals.some(s => s.includes('privacy'))) return "PRIVACY-POLICY-MISSING";

    return "SIGNAL-PENDING";
}

// Map Signal Code to Regulatory Relevance
function getRegulatoryRelevance(code: string | null) {
    if (!code || code === "SIGNAL-PENDING") return null;
    if (code.includes('DATA-PROVENANCE') || code.includes('DOC-GENERAL') || code.includes('GOV-')) return "Article 10";
    if (code.includes('DOC-MODEL') || code.includes('DOC-USAGE')) return "Article 13";
    if (code.includes('RISK-ASSESSMENT') || code.includes('RISK-POLICY')) return "Article 9";
    if (code.includes('PRIVACY')) return "GDPR / Transparency";
    return "Baseline Compliance";
}

// Concrete Finding Generation (Priority-Based)
function getConcreteFinding(report: any) {
    const missing = typeof report.missing_signals === 'string' ? JSON.parse(report.missing_signals) : (report.missing_signals || []);
    const detected = typeof report.detected_signals === 'string' ? JSON.parse(report.detected_signals) : (report.detected_signals || []);
    const summary = report.summary_text || "";

    // 1. First Missing Signal (Highest Priority for Transparency)
    if (missing.length > 0) {
        return `Missing critical artifact: ${missing[0].split(' (')[0]}`;
    }

    // 2. First Detected Signal (If no missing)
    if (detected.length > 0) {
        return `Technical evidence detected for ${detected[0].split(' (')[0]}`;
    }

    // 3. Persisted Summary (if non-generic/short)
    if (summary && summary.length > 20 && !summary.includes("Automated technical analysis indicates")) {
        return summary;
    }

    // 4. Legacy Fallback (Last Resort)
    return "Public technical evidence is limited for this repository.";
}

// Multi-tier Risk Theme Engine
function getRiskTheme(score: number) {
    if (score === 100) return { label: 'Sovereign', rating: 'AAA', color: 'text-[#059669]', bg: 'bg-[#059669]/5', border: 'border-[#059669]/20' };
    if (score >= 90) return { label: 'High Integrity', rating: 'AA', color: 'text-[#10b981]', bg: 'bg-[#10b981]/5', border: 'border-[#10b981]/20' };
    if (score >= 75) return { label: 'Compliant', rating: 'A', color: 'text-[#84cc16]', bg: 'bg-[#84cc16]/5', border: 'border-[#84cc16]/20' };
    if (score >= 50) return { label: 'Elevated Risk', rating: 'B', color: 'text-[#f59e0b]', bg: 'bg-[#f59e0b]/5', border: 'border-[#f59e0b]/20' };
    if (score >= 25) return { label: 'High Risk', rating: 'C', color: 'text-[#f97316]', bg: 'bg-[#f97316]/5', border: 'border-[#f97316]/20' };
    return { label: 'Critical', rating: 'F', color: 'text-[#dc2626]', bg: 'bg-[#dc2626]/5', border: 'border-[#dc2626]/20' };
}

// Missing vs Found Signals (Strict Artifact-Backed)
function getEvidenceSignals(report: any) {
    const detected = typeof report.detected_signals === 'string' ? JSON.parse(report.detected_signals) : (report.detected_signals || []);
    const missing = typeof report.missing_signals === 'string' ? JSON.parse(report.missing_signals) : (report.missing_signals || []);
    
    if (detected.length > 0 || missing.length > 0) {
        return { 
            found: detected.map((s: string) => s.split(' (')[0]).slice(0, 3), 
            missing: missing.map((s: string) => s.split(' (')[0]).slice(0, 3) 
        };
    }

    // Legacy Fallback
    const gaps = typeof report.visible_gaps === 'string' ? JSON.parse(report.visible_gaps) : (report.visible_gaps || []);
    const rules = typeof report.rules_failed === 'string' ? JSON.parse(report.rules_failed) : (report.rules_failed || []);
    const passed = typeof report.rules_passed === 'string' ? JSON.parse(report.rules_passed) : (report.rules_passed || []);
    const artifacts = typeof report.detected_artifacts === 'string' ? JSON.parse(report.detected_artifacts) : (report.detected_artifacts || []);
    
    const legacyMissing = [];
    if (gaps.some((g: string) => g.toLowerCase().includes('model'))) legacyMissing.push('model card');
    if (gaps.some((g: string) => g.toLowerCase().includes('data'))) legacyMissing.push('dataset provenance');

    const legacyFound = [];
    if (passed.some((p: string) => p.includes('license')) || artifacts.includes('LICENSE')) legacyFound.push('LICENSE');
    if (passed.some((p: string) => p.includes('ci_integration'))) legacyFound.push('CI workflow');

    return { missing: legacyMissing.slice(0, 3), found: legacyFound.slice(0, 3) };
}

function getCompactStack(stack: string) {
    if (!stack || stack.includes('Heuristic')) return 'Generic AI';
    return stack.replace('AI Stack: ', '').split(',').slice(0, 2).join(', ');
}
---

<SovereignLayout title={title} description={description}>
  <SovereignHeader client:idle />
  
  <main class="bg-[#F4F1EA] pt-32 pb-24 px-6">
    <div class="max-w-6xl mx-auto">
      
      <header class="mb-12">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8">
            <div class="max-w-2xl">
                <h1 class="text-6xl font-black text-[#0f172a] mb-6 tracking-tighter uppercase italic leading-[0.85]">
                    Intelligence Hub
                </h1>
                <p class="text-xs font-mono font-bold text-[#64748b] uppercase tracking-widest leading-relaxed">
                    Autonomous technical mapping of the global AI ecosystem. Neutral technical assessments based on public repository signals.
                </p>
            </div>
            
            <div class="flex gap-2">
                {['langchain', 'openai', 'rag', 'agents'].map(cat => (
                   <a href={getFilterUrl({ category: category === cat ? null : cat })} class={`px-3 py-1.5 text-[9px] font-black uppercase tracking-widest rounded transition-all border ${category === cat ? 'bg-[#0f172a] text-white border-[#0f172a]' : 'bg-white text-[#0f172a] border-[#0f172a]/10 hover:border-[#0f172a]/30'}`}>
                    {cat}
                   </a>
                ))}
            </div>
        </div>

        <div class="flex flex-wrap items-center justify-between gap-6 pt-6 border-t border-[#0f172a]/5">
            <div class="flex items-center gap-6">
                <div class="flex gap-4">
                    {['all risks', 'low', 'medium', 'high'].map(r => (
                        <a href={getFilterUrl({ risk: r === 'all risks' ? null : r.charAt(0).toUpperCase() + r.slice(1) })} class={`text-[10px] font-bold uppercase tracking-widest ${ (riskFilter === null && r === 'all risks') || (riskFilter === (r.charAt(0).toUpperCase() + r.slice(1))) ? 'text-[#0f172a] border-b-2 border-[#0f172a]' : 'text-[#94a3b8] hover:text-[#0f172a]'}`}>
                            {r}
                        </a>
                    ))}
                </div>

                <!-- Search Input -->
                <form class="relative group">
                    <input 
                        type="text" 
                        name="search"
                        placeholder="Search Intelligence..." 
                        value={search}
                        class="bg-white/50 border border-[#0f172a]/5 rounded-lg pl-8 pr-4 py-1.5 text-[10px] font-mono focus:bg-white focus:border-[#0f172a]/20 outline-none transition-all w-48 md:w-64"
                    />
                    <svg class="absolute left-2.5 top-2 w-3.5 h-3.5 text-[#94a3b8] group-focus-within:text-[#0f172a] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    {riskFilter !== 'all' && <input type="hidden" name="risk" value={riskFilter} />}
                    {category && <input type="hidden" name="category" value={category} />}
                </form>
            </div>
            
            <div class="flex items-center gap-2">
                <span class="text-[9px] font-mono font-bold text-[#94a3b8] uppercase">Order By:</span>
                <select 
                  class="bg-transparent text-[10px] font-black uppercase tracking-widest text-[#0f172a] focus:outline-none cursor-pointer"
                  onchange="window.location.href = this.value"
                >
                    <option value={getFilterUrl({ sort: 'scan_timestamp', order: 'DESC' })} selected={sort === 'scan_timestamp'}>Newest</option>
                    <option value={getFilterUrl({ sort: 'audit_score', order: 'DESC' })} selected={sort === 'audit_score'}>Score</option>
                    <option value={getFilterUrl({ sort: 'stars', order: 'DESC' })} selected={sort === 'stars'}>Popularity</option>
                </select>
            </div>
        </div>
      </header>

      <div class="flex flex-col gap-px bg-[#0f172a]/5 border border-[#0f172a]/5 rounded-xl overflow-hidden shadow-sm">
        <!-- Table Header -->
        <div class="hidden md:grid grid-cols-[1.5fr_0.6fr_1fr_0.6fr_0.6fr_1.2fr_2fr_0.3fr] gap-4 px-6 py-3 bg-[#F4F1EA] text-[9px] font-mono font-bold text-[#94a3b8] uppercase tracking-wider border-b border-[#0f172a]/5">
            <div>Repository</div>
            <div>Stars</div>
            <div>AI Stack</div>
            <div>Score</div>
            <div>Risk</div>
            <div>Signal</div>
            <div>Technical Finding</div>
            <div></div>
        </div>

        <!-- Repository Rows -->
        {reports.map(report => {
            const signalCode = getSignalCode(report);
            const concreteFinding = getConcreteFinding(report);
            const { missing, found } = getEvidenceSignals(report);
            const theme = getRiskTheme(report.audit_score);
            
            return (
                <a 
                    href={`/ai-compliance/${report.slug}`} 
                    class="grid grid-cols-2 md:grid-cols-[1.5fr_0.6fr_1fr_0.6fr_0.6fr_1.2fr_2fr_0.3fr] gap-4 px-6 py-5 bg-white items-center hover:bg-[#F8FAFC] transition-colors group relative border-b border-[#0f172a]/5 last:border-0"
                    data-ai-generated="true"
                    data-ai-system="sentinel-engine"
                    data-ai-disclosure="article-52"
                >
                    <div class="col-span-2 md:col-span-1">
                        <div class={`text-xs font-black uppercase tracking-tight truncate ${theme.color}`}>
                            {report.repo_name}
                        </div>
                    </div>
                    
                    <div class={`text-[10px] font-mono ${theme.color}`}>
                        ★ {report.stars.toLocaleString()}
                    </div>
                    
                    <div>
                        <span class="px-2 py-0.5 bg-[#f1f5f9] text-[#64748b] text-[9px] font-bold rounded uppercase tracking-tighter">
                            {getCompactStack(report.detected_ai_stack)}
                        </span>
                    </div>

                    <div class={`text-xs font-black ${theme.color}`}>
                        {report.audit_score}<span class="text-[8px] opacity-30">/100</span>
                    </div>

                    <div class={`text-[9px] font-black uppercase tracking-widest ${theme.color}`}>
                        {theme.label}
                    </div>

                    <div>
                        {signalCode && (
                            <div class="flex flex-col gap-1 items-center">
                                <span class="px-2 py-1 bg-[#0f172a]/5 border border-[#0f172a]/10 rounded text-[8px] font-mono font-bold text-[#475569] uppercase truncate block w-full text-center">
                                    {signalCode}
                                </span>
                                {getRegulatoryRelevance(signalCode) && (
                                    <span class="text-[7px] font-mono font-bold text-[#3b82f6] uppercase tracking-tighter">
                                        {getRegulatoryRelevance(signalCode)}
                                    </span>
                                )}
                            </div>
                        )}
                        {!signalCode && (
                            <span class="text-[8px] font-mono text-[#94a3b8] uppercase italic block text-center">
                                N/A
                            </span>
                        )}
                    </div>

                    <div class="col-span-2 md:col-span-1 flex flex-col gap-1.5">
                        <div class="text-[10px] font-bold italic text-[#0f172a] leading-tight line-clamp-1">
                            "{concreteFinding}"
                        </div>
                        <div class="flex flex-wrap items-center justify-between gap-2">
                            <div class="flex flex-wrap gap-x-3 gap-y-1">
                                {missing.length > 0 && (
                                    <div class="text-[8px] font-mono text-[#ef4444] uppercase flex items-center gap-1">
                                    <span class="opacity-50 font-bold">Missing:</span> {missing.join(', ')}
                                    </div>
                                )}
                                {found.length > 0 && (
                                    <div class="text-[8px] font-mono text-[#059669] uppercase flex items-center gap-1">
                                    <span class="opacity-50 font-bold">Found:</span> {found.join(', ')}
                                    </div>
                                )}
                            </div>
                            <div class="text-[7px] font-mono font-bold text-[#f59e0b] uppercase tracking-tighter opacity-0 group-hover:opacity-100 transition-opacity">
                                AI-assisted regulatory mapping (Art. 52 Disclosure)
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end">
                        <svg class="w-4 h-4 text-[#94a3b8] group-hover:text-[#0f172a] group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M9 5l7 7-7 7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                </a>
            );
        })}
        {reports.length === 0 && (
          <div class="p-20 text-center bg-white border-t border-[#0f172a]/10">
             <p class="text-[10px] font-mono text-[#94a3b8] uppercase tracking-widest italic">No public technical signals identified in the selected segment.</p>
          </div>
        )}
      </div>

      <!-- Methodology Footer -->
      <section class="mt-16 p-8 bg-white/50 border border-[#0f172a]/5 rounded-2xl">
         <div class="flex items-center gap-3 mb-6">
            <div class="w-1.5 h-1.5 rounded-full bg-[#3b82f6]"></div>
            <h3 class="text-[10px] font-black text-[#0f172a] uppercase tracking-[0.3em]">Automated Intelligence Methodology</h3>
         </div>
         <div class="grid md:grid-cols-2 gap-10">
            <p class="text-[10px] leading-relaxed text-[#64748b]">
                These reports are generated using Sentinel's deterministic compliance engine. Assessments are strictly limited to technical evidence: repository architecture, manifest declarations, and public documentation presence.
                <br/><br/>
                Neutral wording is utilized to describe discovered technical patterns. These reports <strong>do not</strong> constitute a legal determination, legal advice, or an accusation of non-compliance.
            </p>
            <p class="text-[10px] leading-relaxed text-[#64748b]">
                The hub is designed as a technical repository index for engineering and auditing review. We encourage developers to use the <a href="/docs" class="underline font-bold text-[#0f172a]">Sentinel CLI</a> to generate verified technical files.
                <br/><br/>
                Sentinel operates on local clones in read-only mode and does not modify third-party source code.
            </p>
         </div>
      </section>

      <footer class="mt-24 pt-12 border-t border-[#0f172a]/5 flex flex-col items-center">
        <p class="text-[9px] font-mono text-[#94a3b8] uppercase tracking-[0.4em] mb-4 underline decoration-[#3b82f6]/30">Public Technical Evidence Index v1.02</p>
        <p class="text-[9px] text-[#64748b] font-mono uppercase">
           Sync Latency: 42ms // Nodes: 12
        </p>
      </footer>

    </div>
  </main>

  <SovereignFooter client:visible />
</SovereignLayout>
