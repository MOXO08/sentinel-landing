---
import SovereignLayout from '../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../components/react/sentinel/sovereign-footer';
import { DashboardPage } from '../../components/react/sentinel/dashboard-page';

export const prerender = false;
const cookie = Astro.request.headers.get('Cookie') || '';
const match = cookie.match(/sentinel_session=([^;]+)/);
const env = (Astro.locals as any).runtime.env;

if (!match) {
    return Astro.redirect('/dashboard/login');
}

const sessionData = await env.CACHE.get(`session:${match[1]}`);
if (!sessionData) {
    return Astro.redirect('/dashboard/login');
}

const founderId = env?.LEMON_FOUNDER || "a4afd393-f642-41c7-ba71-bec3200ad514";
---

<SovereignLayout title="Sentinel — Compliance Dashboard" description="Manage your AI Act compliance, audit logs, and API infrastructure.">
  <SovereignHeader client:load />
  
  <main class="bg-[#F4F1EA]">
    <DashboardPage client:load founderId={founderId} />
  </main>

  <SovereignFooter client:idle />
</SovereignLayout>
