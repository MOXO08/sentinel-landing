---
import SovereignLayout from '../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../components/react/sentinel/sovereign-footer';
export const partial = false;
---

<SovereignLayout title="Sentinel — Access Authority" description="Enter your credentials to access the Sentinel Compliance Dashboard.">
  <SovereignHeader client:load />

  <main class="min-h-screen bg-[#F4F1EA] flex items-center justify-center p-6 pt-32 pb-24">
    <div class="w-full max-w-[440px] bg-white border border-[#cbd5e1] rounded-[32px] p-10 shadow-sm relative overflow-hidden">
      <!-- Decorative background element -->
      <div class="absolute top-0 right-0 w-32 h-32 bg-[#10b981]/5 rounded-bl-[100px] -mr-10 -mt-10"></div>
      
      <div class="relative z-10 text-center">
        <div class="w-16 h-16 rounded-2xl bg-[#F8FAFC] border border-[#cbd5e1] flex items-center justify-center text-3xl mx-auto mb-8 shadow-sm">
          🛡️
        </div>
        
        <div class="text-[10px] font-mono font-bold text-[#10b981] uppercase tracking-[0.2em] mb-4">Secure Gateway</div>
        <h1 class="text-3xl font-bold text-[#0f172a] mb-3 tracking-tight">Access Authority</h1>
        <p class="text-[#64748b] text-sm mb-10 font-light leading-relaxed">
          Provide your enterprise credentials or administrative bypass to initialize your compliance session.
        </p>

        <div class="space-y-4 text-left">
          <div class="space-y-1.5">
            <label class="text-[10px] font-mono font-bold text-[#94a3b8] uppercase tracking-widest pl-1">Identifier</label>
            <input type="email" id="email" 
                  placeholder="you@company.com" 
                  autocomplete="email"
                  class="w-11/12 md:w-full px-5 py-4 bg-[#F8FAFC] border border-[#cbd5e1] rounded-2xl text-[#0f172a] text-sm focus:border-[#10b981] focus:ring-4 focus:ring-[#10b981]/5 outline-none transition-all placeholder:text-[#94a3b8]" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[10px] font-mono font-bold text-[#94a3b8] uppercase tracking-widest pl-1">Authorization Code</label>
            <input type="password" id="password" 
                  placeholder="Admin Bypass or Code" 
                  autocomplete="current-password"
                  class="w-11/12 md:w-full px-5 py-4 bg-[#F8FAFC] border border-[#cbd5e1] rounded-2xl text-[#0f172a] text-sm focus:border-[#10b981] focus:ring-4 focus:ring-[#10b981]/5 outline-none transition-all placeholder:text-[#94a3b8]" />
          </div>

          <button id="send-btn" 
                  class="w-full bg-[#0f172a] text-white py-5 rounded-2xl font-bold text-sm hover:bg-[#1e293b] active:scale-[0.98] transition-all shadow-lg shadow-[#0f172a]/10 mt-4 flex items-center justify-center gap-2 group">
            Authenticate Session
            <span class="group-hover:translate-x-1 transition-transform">→</span>
          </button>
        </div>

        <div id="msg" class="mt-8 p-4 rounded-2xl text-xs font-medium hidden"></div>

        <p class="mt-10 text-[10px] font-mono text-[#94a3b8] uppercase tracking-widest">
          Sovereign Node Cluster: EEUR-1
        </p>
      </div>
    </div>
  </main>

  <script is:inline>
  async function requestLink() {
    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value.trim();
    const btn = document.getElementById('send-btn');
    const msg = document.getElementById('msg');
    
    if (!email) { showMsg('Identity identifier required.', false); return; }
    
    btn.disabled = true;
    btn.textContent = 'Authenticating...';
    
    try {
      const r = await fetch('/api/dashboard/auth/request', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ email, password })
      });
      const d = await r.json();
      if (r.ok) {
          showMsg(d.message || 'Onboarding packet dispatched to inbox.', true);
          if (d.redirect) {
              setTimeout(() => { window.location = d.redirect; }, 1200);
          }
      } else {
          showMsg(d.error || 'Authentication protocols failed.', false);
          btn.disabled = false;
          btn.textContent = 'Authenticate Session';
      }
    } catch { 
      showMsg('Network synchronization error.', false);
      btn.disabled = false;
      btn.textContent = 'Authenticate Session';
    }
  }

  function showMsg(text, ok) {
    const el = document.getElementById('msg');
    el.textContent = text;
    el.className = ok 
      ? 'mt-8 p-4 rounded-2xl text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-100 flex items-center justify-center gap-2' 
      : 'mt-8 p-4 rounded-2xl text-xs font-medium bg-red-50 text-red-700 border border-red-100 flex items-center justify-center gap-2';
    el.style.display = 'flex';
  }

  document.getElementById('send-btn').addEventListener('click', requestLink);
  document.getElementById('email').addEventListener('keypress', e => { if(e.key==='Enter') requestLink(); });
  document.getElementById('password').addEventListener('keypress', e => { if(e.key==='Enter') requestLink(); });

  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.has('error')) {
      showMsg('Protocol Error: ' + urlParams.get('error'), false);
  }
  </script>
  <SovereignFooter client:idle />
</SovereignLayout>
