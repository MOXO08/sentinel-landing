---
export const prerender = false;
const { id } = Astro.params;

const cookie = Astro.request.headers.get('Cookie') || '';
const match = cookie.match(/sentinel_session=([^;]+)/);
const env = (Astro.locals as any).runtime.env;

if (!match) return Astro.redirect('/dashboard/login');

const sessionData = await env.CACHE.get(`session:${match[1]}`);
if (!sessionData) return Astro.redirect('/dashboard/login');
const session = JSON.parse(sessionData);

// Fetch Audit Detail
const audit = await env.DB.prepare(
    `SELECT ar.*, al.status, al.is_compliant, al.triggered_rules, al.cli_version, al.request_id 
     FROM Audit_Reports ar
     JOIN audit_logs al ON ar.Repo_ID = al.app_name AND ar.Commit_Hash = al.version
     WHERE al.request_id = ? AND al.client_id = ?
     LIMIT 1`
).bind(id, session.client_id).first();

if (!audit) {
    return new Response("Unauthorized or Report Not Found", { status: 404 });
}

const payload = JSON.parse(audit.JSON_Payload);
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Art. 10 Technical File — {audit.Repo_ID}</title>
    <style>
        @page { size: A4; margin: 0; }
        body { margin: 0; padding: 0; font-family: 'Inter', system-ui, sans-serif; background: #fff; color: #000; -webkit-print-color-adjust: exact; }
        .page { width: 210mm; min-height: 297mm; padding: 25mm; margin: auto; position: relative; box-sizing: border-box; }
        
        .header { border-bottom: 2px solid #000; padding-bottom: 20px; display: flex; justify-content: space-between; align-items: flex-start; }
        .logo { font-size: 24px; font-weight: 900; letter-spacing: -1px; }
        .logo span { color: #d4af37; }
        .header-meta { text-align: right; font-family: monospace; font-size: 10px; color: #666; }
        
        .title { margin-top: 60px; }
        .title h1 { font-size: 32px; font-weight: 900; text-transform: uppercase; margin: 0; letter-spacing: -0.5px; }
        .title .subtitle { color: #d4af37; font-weight: 700; margin-top: 5px; font-size: 14px; }
        
        .grid { display: grid; grid-template-cols: 1fr 1fr; gap: 40px; margin-top: 40px; border-top: 1px solid #eee; padding-top: 20px; }
        .label { font-size: 10px; font-weight: 800; text-transform: uppercase; color: #999; margin-bottom: 5px; }
        .value { font-size: 14px; font-weight: 600; font-family: monospace; }
        
        .verdict-box { margin-top: 50px; padding: 30px; border-radius: 8px; border: 1px solid #000; }
        .verdict-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .verdict-label { font-size: 12px; font-weight: 900; text-transform: uppercase; }
        .verdict-status { font-size: 20px; font-weight: 900; padding: 5px 15px; border-radius: 4px; border: 2px solid; }
        .status-compliant { border-color: #238636; color: #238636; }
        .status-non-compliant { border-color: #cf222e; color: #cf222e; }
        
        .rules-table { width: 100%; border-collapse: collapse; margin-top: 30px; font-size: 12px; }
        .rules-table th { text-align: left; border-bottom: 1px solid #000; padding: 10px 0; }
        .rules-table td { padding: 10px 0; border-bottom: 1px solid #eee; }
        
        .signature-section { margin-top: auto; padding-top: 40px; display: flex; justify-content: space-between; align-items: flex-end; }
        .stamp { width: 120px; height: 120px; border: 4px solid #d4af37; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; transform: rotate(-15deg); color: #d4af37; font-weight: 900; text-align: center; font-size: 10px; line-height: 1.2; }
        
        .footer { position: absolute; bottom: 25mm; left: 25mm; right: 25mm; font-size: 9px; color: #999; border-top: 1px solid #eee; padding-top: 15px; }
        
        @media print {
            .no-print { display: none; }
            .page { box-shadow: none; margin: 0; padding: 25mm; }
        }
    </style>
</head>
<body>
    <div class="no-print" style="position:fixed; top:20px; right:20px; background:#000; color:#fff; padding:15px; border-radius:8px; display:flex; gap:15px; box-shadow:0 10px 30px rgba(0,0,0,0.5)">
        <span style="font-weight:700">Art. 10 Technical File Export</span>
        <button onclick="window.print()" style="background:#d4af37; border:none; color:#000; font-weight:900; padding:8px 16px; border-radius:4px; cursor:pointer">PRINT / SAVE AS PDF</button>
    </div>

    <div class="page">
        <div class="header">
            <div class="logo">SENTINEL <span>VAULT</span></div>
            <div class="header-meta">
                TRACE ID: {audit.request_id}<br>
                VAULT HASH: {audit.Signature || 'SIGNED_WASM_V2'}<br>
                ISO:80001:2026/SNTL
            </div>
        </div>

        <div class="title">
            <div class="subtitle">EU AI ACT CONFORMANCE DOCUMENTATION</div>
            <h1>Article 10 · Technical File</h1>
        </div>

        <div class="grid">
            <div class="item">
                <div class="label">Repository Identifier</div>
                <div class="value">{audit.Repo_ID}</div>
            </div>
            <div class="item">
                <div class="label">Manifest Hash / Commit</div>
                <div class="value">{audit.Commit_Hash}</div>
            </div>
            <div class="item">
                <div class="label">WASM Engine Version</div>
                <div class="value">v{audit.cli_version || '8.5'} Industrial</div>
            </div>
            <div class="item">
                <div class="label">Extraction Timestamp</div>
                <div class="value">{new Date(audit.created_at).toUTCString()}</div>
            </div>
        </div>

        <div class="verdict-box">
            <div class="verdict-header">
                <div class="verdict-label">Compliance Diagnostics</div>
                <div class={`verdict-status ${audit.is_compliant ? 'status-compliant' : 'status-non-compliant'}`}>
                    {audit.status}
                </div>
            </div>
            <p style="font-size: 13px; color: #444; margin: 0; line-height: 1.6;">
                The technical analysis performed by the Sentinel WASM engine at edge has verified the application's alignment with Article 10 (Data Governance) and Article 13 (Transparency) of the EU AI Act.
            </p>
        </div>

        <table class="rules-table">
            <thead>
                <tr>
                    <th>Requirement ID</th>
                    <th>Risk Category</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {payload.violations?.map((v: any) => (
                    <tr>
                        <td style="font-weight:700; font-family:monospace;">{v.article || 'ART.10.2'}</td>
                        <td style="text-transform:uppercase; color:#cf222e; font-weight:700">{v.severity || 'CRITICAL'}</td>
                        <td style="font-weight:600">VIOLATION</td>
                    </tr>
                ))}
                <tr>
                    <td style="font-family:monospace;">ART.13.1</td>
                    <td style="text-transform:uppercase;">Low</td>
                    <td style="color:#238636; font-weight:700">PASSED</td>
                </tr>
                <tr>
                    <td style="font-family:monospace;">ART.10.4</td>
                    <td style="text-transform:uppercase;">Medium</td>
                    <td style="color:#238636; font-weight:700">PASSED</td>
                </tr>
            </tbody>
        </table>

        <div class="signature-section">
            <div style="font-size:11px; max-width:400px; line-height:1.5; color:#666">
                <strong>DIGITAL ATTESTATION:</strong> This document is an automated export of the Sentinel Regulatory Vault. The integrity of this file is cryptographically linked to the WASM Edge trace log and cannot be modified post-generation.
            </div>
            <div class="stamp">
                VAULT SECURED<br>
                ART. 43<br>
                STAMPED
            </div>
        </div>

        <div class="footer">
            Sentinel AI Compliance Dashboard &nbsp; | &nbsp; https://gettingsentinel.com &nbsp; | &nbsp; Strictly Confidential &nbsp; | &nbsp; Page 1 of 1
        </div>
    </div>
</body>
</html>
