---
export const prerender = false;
const cookie = Astro.request.headers.get('Cookie') || '';
const match = cookie.match(/sentinel_session=([^;]+)/);
const env = (Astro.locals as any).runtime.env;

if (!match) {
    return Astro.redirect('/dashboard/login');
}

const sessionData = await env.CACHE.get(`session:${match[1]}`);
if (!sessionData) {
    return Astro.redirect('/dashboard/login');
}

export const partial = false;
---
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Sentinel — Data Health HUD (Art. 10)</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:#0a0d12;color:#e6edf3;font-family:system-ui,sans-serif}
  nav{display:flex;align-items:center;justify-content:space-between;padding:16px 32px;background:#111621;border-bottom:1px solid #21262d}
  .logo{font-weight:700;font-size:1.1rem;cursor:pointer}
  .logo span{color:#39d0dc}
  .btn-sm{padding:8px 16px;border-radius:6px;border:1px solid #21262d;background:transparent;color:#e6edf3;cursor:pointer;font-size:0.85rem;transition:border-color .2s}
  .btn-sm:hover{border-color:#39d0dc}
  main{max-width:1000px;margin:40px auto;padding:0 24px;display:grid;grid-template-columns: 1fr 350px;gap:20px}
  @media (max-width: 800px) { main { grid-template-columns: 1fr; } }
  .card{background:#111621;border:1px solid #21262d;border-radius:12px;padding:28px}
  .card h2{font-size:1rem;font-weight:700;color:#7d8590;text-transform:uppercase;letter-spacing:.06em;margin-bottom:20px}
  .score-circle { width: 120px; height: 120px; border-radius: 50%; border: 8px solid #21262d; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 800; margin: 0 auto 20px; }
  .score-good { border-color: #238636; color: #3fb950; }
  .score-bad { border-color: #f85149; color: #f85149; }
  .score-warning { border-color: #d29922; color: #d29922; }
  .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 20px; }
  .stat-item { background: #0d1117; padding: 16px; border-radius: 8px; border: 1px solid #21262d; text-align: center; }
  .stat-label { font-size: 0.75rem; color: #7d8590; text-transform: uppercase; margin-bottom: 4px; }
  .stat-value { font-size: 1.2rem; font-weight: 700; }
  .radar-container { width: 100%; height: 300px; background: #0d1117; border-radius: 8px; border: 1px solid #21262d; margin-top: 20px; position: relative; }
  .export-btn { width: 100%; padding: 14px; background: #39d0dc; color: #0a0d12; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; transition: transform 0.1s; margin-top: 20px; }
  .export-btn:active { transform: scale(0.98); }
  .badge { padding: 4px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
  .badge-enterprise { background: rgba(57, 208, 220, 0.1); color: #39d0dc; border: 1px solid rgba(57, 208, 220, 0.3); }
</style>
</head>
<body>
<nav>
  <div class="logo" onclick="window.location='/dashboard'">&#x1F6E1; <span>Sentinel</span> Data Health</div>
  <div style="display:flex;gap:12px">
    <span class="badge badge-enterprise">Enterprise Tier</span>
    <form action="/api/dashboard/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn-sm">Sign out</button>
    </form>
  </div>
</nav>

<main>
  <div class="card">
    <h2>Article 10: Data Governance Deep Audit</h2>
    <p style="color:#7d8590;font-size:0.9rem;margin-bottom:24px">
      Visualizing dataset representativeness and bias indicators as required by EU AI Act Article 10.3.
    </p>
    
    <div class="radar-container">
      <canvas id="healthChart"></canvas>
    </div>

    <div class="stat-grid">
      <div class="stat-item">
        <div class="stat-label">Bias Imbalance</div>
        <div class="stat-value" id="bias-val">--%</div>
      </div>
      <div class="stat-item">
        <div class="stat-label">Coverage Quality</div>
        <div class="stat-value" id="quality-val">--%</div>
      </div>
    </div>

    <div style="margin-top:30px">
        <h2 style="font-size:0.8rem">Audit Conclusion (Heuristics)</h2>
        <div id="conclusion-text" style="font-size:0.9rem;line-height:1.5;color:#e6edf3;background:rgba(255,255,255,0.03);padding:16px;border-radius:8px">
            Select a repository and commit to view Article 10 analysis.
        </div>
    </div>
  </div>

  <div class="card" style="text-align:center">
    <h2>Compliance Status</h2>
    <div id="score-circle" class="score-circle">--</div>
    <div style="font-size:0.85rem;color:#7d8590">Data Health Score</div>
    
    <div style="margin-top:40px;text-align:left">
        <h2 style="font-size:0.8rem">Regulatory Controls</h2>
        <button class="export-btn" id="export-btn">
            📥 Generate Art. 11 Tech File (PDF)
        </button>
        <p style="font-size:0.7rem;color:#7d8590;margin-top:12px">
            * This export satisfies the <strong>Article 11</strong> requirement for technical documentation regarding training datasets and bias mitigation.
        </p>
    </div>
  </div>
</main>

<script is:inline>
async function loadHealthData() {
    const params = new URLSearchParams(window.location.search);
    const repo = params.get('repo') || 'default';
    const commit = params.get('commit') || 'latest';
    
    try {
        const r = await fetch(`/api/v1/data-health?repo=${encodeURIComponent(repo)}&commit=${encodeURIComponent(commit)}`);
        const data = await r.json();
        
        if (data.error) {
            document.getElementById('conclusion-text').textContent = "No Article 10 telemetry found for this commit. Ensure the Sentinel GitHub Action is updated.";
            return;
        }

        renderHealth(data);
    } catch(e) {
        console.error(e);
    }
}

function renderHealth(data) {
    const score = data.Data_Health_Score;
    const circle = document.getElementById('score-circle');
    circle.textContent = score;
    circle.className = 'score-circle ' + (score > 80 ? 'score-good' : (score > 50 ? 'score-warning' : 'score-bad'));

    const distribution = JSON.parse(data.Distribution_Payload || '{}');
    const categories = Object.keys(distribution);
    const values = Object.values(distribution);

    document.getElementById('bias-val').textContent = (Math.max(...values, 0) * 100).toFixed(1) + '%';
    document.getElementById('quality-val').textContent = (score * 0.95).toFixed(1) + '%';

    document.getElementById('conclusion-text').innerHTML = `
        <strong>Verificator:</strong> Sentinel Engine v7.6 (Art 10 Explorer)<br>
        <strong>Finding:</strong> Detected distribution spread of ${categories.length} segments. 
        ${score < 80 ? '<span style="color:#f85149">Imbalance exceeds Article 10.3 safety thresholds.</span>' : '<span style="color:#3fb950">Statistically representative dataset detected.</span>'}
    `;

    drawDistribution(distribution);
}

function drawDistribution(dist) {
    const canvas = document.getElementById('healthChart');
    const p = canvas.parentElement;
    canvas.width = p.offsetWidth * 2; canvas.height = p.offsetHeight * 2;
    const ctx = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;
    
    const keys = Object.keys(dist);
    const vals = Object.values(dist);
    if (!keys.length) return;

    const centerX = W / 2, centerY = H / 2, radius = Math.min(W, H) / 2.5;

    // Draw Radar Background
    ctx.strokeStyle = '#21262d'; ctx.lineWidth = 2;
    for (let r = 1; r <= 5; r++) {
        ctx.beginPath();
        for (let i = 0; i < keys.length; i++) {
            const ang = (i / keys.length) * Math.PI * 2 - Math.PI / 2;
            const x = centerX + Math.cos(ang) * (radius * r / 5);
            const y = centerY + Math.sin(ang) * (radius * r / 5);
            if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
        }
        ctx.closePath(); ctx.stroke();
    }

    // Draw Labels
    ctx.fillStyle = '#7d8590'; ctx.font = '24px system-ui'; ctx.textAlign = 'center';
    keys.forEach((k, i) => {
        const ang = (i / keys.length) * Math.PI * 2 - Math.PI / 2;
        const x = centerX + Math.cos(ang) * (radius * 1.2);
        const y = centerY + Math.sin(ang) * (radius * 1.2);
        ctx.fillText(k.toUpperCase(), x, y);
    });

    // Draw Data Area
    ctx.fillStyle = 'rgba(57, 208, 220, 0.4)';
    ctx.strokeStyle = '#39d0dc'; ctx.lineWidth = 4;
    ctx.beginPath();
    keys.forEach((k, i) => {
        const ang = (i / keys.length) * Math.PI * 2 - Math.PI / 2;
        const v = dist[k];
        const x = centerX + Math.cos(ang) * (radius * v);
        const y = centerY + Math.sin(ang) * (radius * v);
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    });
    ctx.closePath(); ctx.fill(); ctx.stroke();
}

document.getElementById('export-btn').onclick = () => {
    alert("Generating Article 11 Technical Documentation PDF... (Secure Link will be sent to office@gettingsentinel.com)");
};

loadHealthData();
</script>
</body></html>
