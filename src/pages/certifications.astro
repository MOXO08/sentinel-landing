---
import SovereignLayout from '../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../components/react/sentinel/sovereign-footer';
export const prerender = true;
---

<SovereignLayout title="Compliance Status & Certifications | Sentinel Authority" description="Self-Assessed Compliance Matrix for the Sentinel AI platform.">
  <SovereignHeader client:load />

  <main class="bg-[#F4F1EA] py-32 min-h-screen">
    <div class="max-w-screen-lg mx-auto px-6">
      
      <!-- Header -->
      <div class="mb-16">
        <div class="text-[10px] font-mono font-bold text-[#10b981] uppercase tracking-[0.2em] mb-4 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-[#10b981] animate-pulse"></span>
            System Trust Anchor
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-[#0f172a] mb-6 tracking-tight">
          Compliance & Certifications
        </h1>
        <p class="text-[#475569] max-w-2xl leading-relaxed text-sm md:text-base">
          This self-assessed matrix maps Sentinel’s technical infrastructure capabilities (WASM, D1 Ledger, Edge Architecture) against global regulatory frameworks and security standards. It is designed to assist Enterprise procurement and compliance teams.
        </p>
      </div>

      <!-- Compliance Matrix -->
      <div class="bg-white rounded-2xl shadow-sm border border-[#e2e8f0] overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse min-w-[800px]">
            <thead>
              <tr class="bg-[#0f172a] text-white text-xs uppercase tracking-wider font-semibold">
                <th class="px-6 py-5 rounded-tl-xl border-b border-[#334155]">&nbsp; Standard / Regulation</th>
                <th class="px-6 py-5 border-b border-[#334155]">Sentinel Solution (Core Tech)</th>
                <th class="px-6 py-5 rounded-tr-xl border-b border-[#334155]">Assessment Status</th>
              </tr>
            </thead>
            <tbody class="text-sm divide-y divide-[#e2e8f0]">
              
              <!-- GDPR -->
              <tr class="hover:bg-[#f8fafc] transition-colors group">
                <td class="px-6 py-6 border-r border-[#e2e8f0]/50 w-1/3">
                  <div class="font-bold text-[#0f172a] mb-1">GDPR / EU Data Residency</div>
                  <div class="text-xs text-[#64748b] leading-relaxed">
                    General Data Protection Regulation. Strict requirements for data localization and export.
                  </div>
                </td>
                <td class="px-6 py-6 border-r border-[#e2e8f0]/50 w-1/3">
                  <div class="flex flex-col gap-2">
                    <span class="font-mono text-xs text-[#0f172a] bg-[#f1f5f9] px-2 py-1 rounded inline-flex w-fit items-center gap-2 border border-[#cbd5e1]">
                        <span class="text-[10px]">🇪🇺</span> Data Residency (EEUR-1 Frankfurt)
                    </span>
                    <span class="font-mono text-xs text-[#0f172a] bg-[#f1f5f9] px-2 py-1 rounded inline-flex w-fit items-center gap-2 border border-[#cbd5e1]">
                        <span class="text-[10px]">🛡</span> Zero-Egress Architecture
                    </span>
                  </div>
                </td>
                <td class="px-6 py-6 align-middle w-1/3">
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-100 text-emerald-800 text-xs font-bold uppercase tracking-wide border border-emerald-200 shadow-[0_0_10px_rgba(16,185,129,0.2)]">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    Compliant
                  </span>
                </td>
              </tr>

              <!-- EU AI Act -->
              <tr class="hover:bg-[#f8fafc] transition-colors group">
                <td class="px-6 py-6 border-r border-[#e2e8f0]/50 w-1/3">
                  <div class="font-bold text-[#0f172a] mb-1">EU AI Act (Art. 12 & 43)</div>
                  <div class="text-xs text-[#64748b] leading-relaxed">
                    Record-keeping/Traceability and conformity assessment procedure requirements.
                  </div>
                </td>
                <td class="px-6 py-6 border-r border-[#e2e8f0]/50 w-1/3">
                  <div class="flex flex-col gap-2">
                    <span class="font-mono text-xs text-[#0f172a] bg-[#f1f5f9] px-2 py-1 rounded inline-flex w-fit items-center gap-2 border border-[#cbd5e1]">
                        <span class="text-[10px]">🔒</span> D1 Ledger-Lock (Traceability)
                    </span>
                    <span class="font-mono text-xs text-[#0f172a] bg-[#f1f5f9] px-2 py-1 rounded inline-flex w-fit items-center gap-2 border border-[#cbd5e1]">
                        <span class="text-[10px]">📜</span> Art. 43 Compliance Certificate
                    </span>
                  </div>
                </td>
                <td class="px-6 py-6 align-middle w-1/3">
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold uppercase tracking-wide border border-blue-200">
                     <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    Ready
                  </span>
                </td>
              </tr>

               <!-- CISA / NIST -->
               <tr class="hover:bg-[#f8fafc] transition-colors group">
                <td class="px-6 py-6 border-r border-[#e2e8f0]/50 w-1/3">
                  <div class="font-bold text-[#0f172a] mb-1">CISA / NIST Best Practices</div>
                  <div class="text-xs text-[#64748b] leading-relaxed">
                    American standards for cyber resilience and "Secure by Design".
                  </div>
                </td>
                <td class="px-6 py-6 border-r border-[#e2e8f0]/50 w-1/3">
                  <div class="flex flex-col gap-2">
                    <span class="font-mono text-xs text-[#0f172a] bg-[#f1f5f9] px-2 py-1 rounded inline-flex w-fit items-center gap-2 border border-[#cbd5e1]">
                        <span class="text-[10px]">🤝</span> Vulnerability Disclosure (VDP)
                    </span>
                    <span class="font-mono text-xs text-[#0f172a] bg-[#f1f5f9] px-2 py-1 rounded inline-flex w-fit items-center gap-2 border border-[#cbd5e1]">
                        <span class="text-[10px]">🪤</span> Active Deception (Honeypots)
                    </span>
                  </div>
                </td>
                <td class="px-6 py-6 align-middle w-1/3">
                   <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-purple-100 text-purple-800 text-xs font-bold uppercase tracking-wide border border-purple-200 shadow-[0_0_10px_rgba(168,85,247,0.2)]">
                     <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    Exceeded
                  </span>
                </td>
              </tr>

              <!-- Data Privacy -->
              <tr class="hover:bg-[#f8fafc] transition-colors group">
                <td class="px-6 py-6 border-r border-[#e2e8f0]/50 w-1/3">
                  <div class="font-bold text-[#0f172a] mb-1">Data Privacy & Isolation</div>
                  <div class="text-xs text-[#64748b] leading-relaxed">
                    Essential standards for memory partitioning and preventing process leakage.
                  </div>
                </td>
                <td class="px-6 py-6 border-r border-[#e2e8f0]/50 w-1/3">
                  <div class="flex flex-col gap-2">
                    <span class="font-mono text-xs text-[#0f172a] bg-[#f1f5f9] px-2 py-1 rounded inline-flex w-fit items-center gap-2 border border-[#cbd5e1]">
                        <span class="text-[10px]">⚡</span> WASM Isolation (Sandboxed Execution)
                    </span>
                  </div>
                </td>
                <td class="px-6 py-6 align-middle w-1/3">
                   <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-slate-100 text-slate-800 text-xs font-bold uppercase tracking-wide border border-slate-300">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Verified
                  </span>
                </td>
              </tr>

            </tbody>
          </table>
        </div>
      </div>

      <!-- Legal Disclaimer Footer -->
      <div class="mt-8 text-xs text-[#64748b] bg-white p-4 rounded-xl border border-[#e2e8f0] flex items-start gap-3">
        <svg class="w-5 h-5 text-[#94a3b8] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <p>
          <strong>Legal Statement:</strong> This matrix reflects the technical capabilities hard-coded into the network architecture (Cloudflare Edge). Sentinel does not provide direct legal advice. For official certification recognized by an authorized Notified Body, this document will serve as the technical foundation for Art. 11/43 (EU AI Act).
        </p>
      </div>

    </div>
  </main>

  <SovereignFooter client:idle />
</SovereignLayout>
