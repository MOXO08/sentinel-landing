---
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

const { id } = Astro.params;
const { DB } = Astro.locals.runtime.env;

let report = null;
let error = null;

try {
  const result = await DB.prepare(
    "SELECT * FROM Audit_Reports WHERE Repo_ID = ? OR Commit_Hash = ? LIMIT 1"
  ).bind(id, id).first();
  
  if (result) {
    report = {
      ...result,
      payload: JSON.parse(result.JSON_Payload)
    };
  } else {
    error = "Report not found or still processing.";
  }
} catch (e) {
  console.error("D1 Fetch Error:", e);
  error = "Infrastructure connection issue. Please retry.";
}

const scoreColor = report?.Scor_Compliance >= 80 ? 'text-emerald-400' : report?.Scor_Compliance >= 50 ? 'text-amber-400' : 'text-red-400';
const borderColor = report?.Scor_Compliance >= 80 ? 'border-emerald-500/20' : report?.Scor_Compliance >= 50 ? 'border-amber-500/20' : 'border-red-500/20';
---

<Layout title={`Shadow Audit: ${report?.Repo_ID || 'Not Found'}`}>
  <main class="min-h-screen pt-32 pb-20 px-6 container mx-auto max-w-4xl">
    {error ? (
      <div class="glass p-12 rounded-3xl text-center border-red-500/20">
        <div class="text-4xl mb-6">🔍</div>
        <h1 class="text-2xl font-bold text-white mb-4">{error}</h1>
        <p class="text-slate-400 mb-8">If this is a recent audit, it might take a few seconds to propagate.</p>
        <a href="/" class="btn-emerald inline-flex">Return to Safety</a>
      </div>
    ) : (
      <div class={`glass p-8 md:p-12 rounded-[2rem] border ${borderColor} relative overflow-hidden`}>
        <!-- Background Glow -->
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-emerald-500/10 blur-[100px] rounded-full"></div>
        
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-12 relative z-10">
          <div>
            <div class="section-label mb-2">SHADOW AUDIT REPORT (UNCLAIMED)</div>
            <h1 class="text-3xl md:text-4xl font-black text-white tracking-tight mb-2">
              {report.Repo_ID}
            </h1>
            <p class="mono text-xs text-slate-500 uppercase tracking-widest">
              COMMIT: {report.Commit_Hash.substring(0, 12)}...
            </p>
          </div>
          
          <div class="flex flex-col items-center">
            <div class={`text-6xl font-black ${scoreColor} mb-1`}>
              {report.Scor_Compliance}
            </div>
            <div class="mono text-[10px] text-slate-500 font-bold">COMPLIANCE SCORE</div>
          </div>
        </div>

        <!-- Risk Summary -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12 relative z-10">
          <div class="bg-slate-900/50 border border-slate-800 p-6 rounded-2xl">
            <h3 class="mono text-xs font-bold text-slate-400 mb-4 uppercase">AI Act Status</h3>
            <div class={`text-xl font-bold ${report.payload.verdict === 'COMPLIANT' ? 'text-emerald-400' : 'text-red-400'}`}>
              {report.payload.verdict.replace(/_/g, ' ')}
            </div>
          </div>
          <div class="bg-slate-900/50 border border-slate-800 p-6 rounded-2xl">
            <h3 class="mono text-xs font-bold text-slate-400 mb-4 uppercase">Engine Version</h3>
            <div class="text-xl font-bold text-white">Sentinel WASM v2.1</div>
          </div>
        </div>

        <!-- Violations List -->
        <div class="space-y-4 mb-12 relative z-10">
          <h3 class="section-label mb-6">Detected Anomalies ({report.payload.violations?.length || 0})</h3>
          
          {report.payload.violations?.map((v) => (
            <div class="bg-slate-900/30 border border-slate-800/50 p-6 rounded-2xl flex flex-col gap-4">
              <div class="flex justify-between items-start">
                <div>
                  <span class="text-[10px] bg-red-500/10 text-red-400 border border-red-500/20 px-2 py-0.5 rounded-full mono font-bold mr-2">
                    {v.article}
                  </span>
                  <span class="text-white font-bold">{v.description}</span>
                </div>
                <span class="mono text-[10px] text-slate-600">{v.severity}</span>
              </div>
              
              <div class="bg-indigo-500/5 border border-indigo-500/10 p-4 rounded-xl">
                <div class="text-[10px] text-indigo-400 mono font-bold mb-2 uppercase tracking-tighter">Recommended Fix (The Fix):</div>
                <code class="text-xs text-indigo-300 block">{v.fix_snippet}</code>
              </div>
            </div>
          ))}
          
          {report.payload.violations?.length === 0 && (
            <div class="text-center py-12 glass border-dashed border-slate-800">
              <div class="text-emerald-400 text-3xl mb-4">🛡️</div>
              <p class="text-slate-400">No prohibited practices or high-risk violations detected.</p>
            </div>
          )}
        </div>

        <!-- CTA -->
        <div class="relative z-10 bg-emerald-500/10 border border-emerald-500/20 p-8 rounded-3xl text-center">
          <h2 class="text-xl font-bold text-white mb-4">Secure your CI/CD with Continuous Monitoring</h2>
          <p class="text-slate-400 text-sm mb-8 max-w-md mx-auto">
            This report was snapshots via Sentinel Shadow Audit. Install the GitHub App to enable real-time risk mitigation and automated compliance signatures.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/report/article43/${id}`} class="btn-emerald">Draft Article 43 Proof →</a>
            <button onclick="document.getElementById('reserve-modal').style.display='flex'" class="px-8 py-3 rounded-xl border border-slate-700 text-white font-bold hover:bg-slate-800 transition-all">Install GitHub App</button>
          </div>
        </div>
      </div>
    )}

    <div class="mt-8 text-center mono text-[9px] text-slate-600 uppercase tracking-widest">
      Cryptographic Signature: {report?.Signature || 'PENDING_AT_EDGE'}
    </div>
  </main>
</Layout>

<style>
  .glass {
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
</style>
