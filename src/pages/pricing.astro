---
import SovereignLayout from '../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../components/react/sentinel/sovereign-footer';
import { PricingPage } from '../components/react/sentinel/pricing-page';

const seoTitle = "Pricing & Solution Offerings | Sentinel Sovereign Trust";
const seoDescription = "Transparent, deterministic pricing for EU AI Act compliance. From individual audit reports to continuous CI/CD 'Watchtower' protection.";
---

<SovereignLayout title={seoTitle} description={seoDescription}>
  <SovereignHeader client:load activePage="/pricing" />
  
  <main class="bg-[#F4F1EA]">
    <PricingPage client:load />
  </main>

  <SovereignFooter client:idle />
</SovereignLayout>
