async function generateProforma() {
  const modal = document.getElementById('proforma-modal');
  const btn = document.getElementById('proforma-gen-btn');
  const auditId = "88X2"; // This would be dynamic in a real app or pulled from URL/localstorage/session
  
  const email = prompt("Enter your CORPORATE email for Proforma Invoice generation:");
  if (!email || !email.includes("@")) return;

  btn.disabled = true;
  btn.textContent = "GENERATING PDF & PAUSING CLOCK...";

  try {
    const res = await fetch(`https://sentinel-api.pages.dev/api/pause-decay?id=${auditId}&email=${encodeURIComponent(email)}`);
    const data = await res.json();

    if (res.ok) {
      alert(`✅ Proforma #PF-2026-88X2 generated!\n\nTechnical File Decay has been PAUSED for 72 hours.\nYour audit data is secured. Check ${email} for the document.`);
      window.location.reload();
    } else {
      alert(`⚠️ ERROR: ${data.message || 'Failed to pause decay'}`);
    }
  } catch (err) {
    alert("❌ Network Error: Could not connect to Sentinel API.");
  } finally {
    btn.disabled = false;
    btn.textContent = "Generate & Freeze Audit Clock →";
  }
}

// Attach event listener to the button
document.getElementById('proforma-gen-btn')?.addEventListener('click', generateProforma);

(function(){
  const rev=document.getElementById('calc-revenue'),cat=document.getElementById('calc-category'),pen=document.getElementById('calc-penalty'),det=document.getElementById('calc-detail'),cta=document.getElementById('calc-cta-amount');
  function fmt(n){return'€'+Math.round(n).toLocaleString('de-DE');}
  function rc(){
    const r=parseFloat(rev?.value)||50000000,rate=parseFloat(cat?.value)||0.07,p=r*rate;
    if(pen)pen.textContent=fmt(p);
    if(det)det.textContent=(rate*100).toFixed(1)+'% of '+fmt(r)+' · '+(cat?.options[cat.selectedIndex]?.text?.split(' — ')[0]||'');
    if(cta)cta.textContent=fmt(p);
  }
  rev?.addEventListener('input',rc);cat?.addEventListener('change',rc);rc();
})();
</script>
