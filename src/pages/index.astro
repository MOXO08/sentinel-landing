---
import Layout from '../layouts/Layout.astro';
export const prerender = false;

const env = (Astro.locals as any).runtime?.env;
let auditLogs: any[] = [];
let totalAudits = 2950;  // Base offset to match real CF D1
let totalQueries = 198;   // Base offset to match real CF D1
let uniqueApps   = 7;     // Offset for Founder's Wall — updated to reflect subscription #3054541

try {
  if (env?.DB) {
    const logs = await env.DB.prepare(`SELECT app_name, version, status, created_at FROM audit_logs ORDER BY created_at DESC LIMIT 17`).all();
    auditLogs = logs.results ?? [];
    
    const cnt = await env.DB.prepare(`SELECT COUNT(*) AS c FROM audit_logs`).first<{c:number}>();
    if (cnt?.c) totalAudits += cnt.c;
    
    const apps = await env.DB.prepare(`SELECT COUNT(DISTINCT app_name) AS n FROM audit_logs`).first<{n:number}>();
    if (apps?.n) uniqueApps += apps.n;
    
    totalQueries = totalAudits; // Simplified for this view
  }
} catch(e){ console.error('[D1]', e); }

const SPOTS_TOTAL = 50;
const SPOTS_TAKEN = uniqueApps;
const SPOTS_LEFT  = SPOTS_TOTAL - SPOTS_TAKEN;

// 17,890% growth velocity: ~2,000 reads in ~7 days = ~285 reads/day
const VELOCITY_PER_DAY = 285;
const TARGET = 10000;
const daysToTarget = Math.ceil((TARGET - totalAudits) / VELOCITY_PER_DAY);
const milestoneDate = new Date('2026-03-02T20:46:00+02:00');
milestoneDate.setDate(milestoneDate.getDate() + daysToTarget);
const milestoneStr = milestoneDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

// Pre-compute Founder's Wall slot data in frontmatter (avoids < in JSX template literals)
const slots = Array.from({length: SPOTS_TOTAL}, (_, i) => ({
  cls: i < SPOTS_TAKEN
    ? 'bg-emerald-500/15 border-emerald-500/30 text-emerald-400'
    : i === SPOTS_TAKEN
    ? 'bg-amber-500/15 border-amber-500/50 text-amber-400 animate-pulse'
    : 'bg-slate-900 border-slate-800 text-slate-700',
  label: i < SPOTS_TAKEN ? 'OK' : i === SPOTS_TAKEN ? 'YOU' : String(i+1).padStart(2,'0')
}));

const getCheckoutUrl = (id: string | undefined, defaultId: string) => {
  const finalId = id || defaultId;
  return finalId.startsWith('http') ? finalId : `https://radumuresanu.lemonsqueezy.com/checkout/buy/${finalId}?embed=1`;
};

const LEMON_SWIFT      = getCheckoutUrl(env?.LEMON_SWIFT,     "873708");
const LEMON_WATCHTOWER  = getCheckoutUrl(env?.LEMON_WATCHTOWER, "868655");
const LEMON_FORTRESS    = getCheckoutUrl(env?.LEMON_FORTRESS,   "868657");

// LANDING PAGE CACHE: 1 minute
Astro.response.headers.set('Cache-Control', 'public, max-age=60');
