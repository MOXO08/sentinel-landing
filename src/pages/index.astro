---
import SovereignLayout from '../layouts/SovereignLayout.astro';
import Hero from '../components/astro/Hero.astro';
import Quickstart from '../components/astro/Quickstart.astro';
import CiCdIntegration from '../components/astro/CiCdIntegration.astro';
import AdoptionSection from '../components/astro/AdoptionSection.astro';
import InfrastructureSection from '../components/astro/InfrastructureSection.astro';
import FinalCTA from '../components/astro/FinalCTA.astro';
import ComplianceSpecs from '../components/astro/ComplianceSpecs.astro';
import WhySentinel from '../components/astro/WhySentinel.astro';
import ArchitectureDiagram from '../components/astro/ArchitectureDiagram.astro';
import BuiltForEngineering from '../components/astro/BuiltForEngineering.astro';
import { SovereignHeader } from '../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../components/react/sentinel/sovereign-footer';

export const prerender = false;

// LANDING PAGE CACHE: 1 minute
Astro.response.headers.set('Cache-Control', 'public, max-age=60');

const env = (Astro.locals as any).runtime?.env;
let totalAudits = 0;  // Real-time counter base

try {
  if (env?.DB) {
    const cnt = await env.DB.prepare(`SELECT COUNT(*) AS c FROM audit_logs`).first<{c:number}>();
    if (cnt?.c) {
      totalAudits += cnt.c;
    }
  }
} catch {
  // Silent fail for production resilience
}
---

<SovereignLayout title="Sentinel — AI Compliance Infrastructure for CI/CD">
  <SovereignHeader client:idle />
  <main class="bg-[#F4F1EA]">
    <Hero totalAudits={totalAudits} />
    <WhySentinel />
    <Quickstart />
    <ArchitectureDiagram />
    <CiCdIntegration />
    <AdoptionSection totalAudits={totalAudits} />
    <BuiltForEngineering />
    <InfrastructureSection />
    <FinalCTA />
    <ComplianceSpecs />
  </main>
  <SovereignFooter client:visible />
</SovereignLayout>
