---
import SovereignLayout from '../../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../../components/react/sentinel/sovereign-footer';

export const prerender = false;

const env = (Astro.locals as any).runtime?.env;

let runs = [] as any[];

try {
  if (env?.DB) {
     const result = await env.DB.prepare(`
        SELECT * FROM discovery_runs 
        ORDER BY started_at DESC 
        LIMIT 50
     `).all();
     runs = result.results || [];
  }
} catch (e) {
  console.error("Discovery Runs Error:", e);
}
---

<SovereignLayout title="Discovery Runs | Sentinel Admin">
  <SovereignHeader client:idle />
  
  <main class="bg-[#F4F1EA] pt-32 pb-24 px-6 min-h-screen font-sans">
    <div class="max-w-6xl mx-auto">
      <!-- Breadcrumbs -->
      <nav class="flex mb-8 text-[10px] font-mono uppercase tracking-widest text-[#94a3b8] gap-2">
        <a href="/admin" class="hover:text-[#0f172a]">HQ</a>
        <span>/</span>
        <span class="text-[#0f172a] font-bold">Discovery History</span>
      </nav>

      <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
        <div>
          <h1 class="text-4xl font-black text-[#0f172a] mb-2 tracking-tight italic uppercase">Discovery Runs</h1>
          <p class="text-[#64748b] font-mono text-[10px] uppercase tracking-[0.2em]">Automated Intelligence Lifecycle Tracking</p>
        </div>
      </div>

      <!-- Runs Table -->
      <div class="bg-white rounded-3xl border border-[#e2e8f0] shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead class="bg-[#f8fafc] border-b border-[#e2e8f0] font-mono text-[10px] uppercase tracking-[0.2em] text-[#64748b]">
              <tr>
                <th class="p-6">Run ID / Start Time</th>
                <th class="p-6">Status</th>
                <th class="p-6">Performance Matrix</th>
                <th class="p-6">Duration</th>
                <th class="p-6 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[#f1f5f9]">
              {runs.map((run) => (
                <tr class="group hover:bg-[#F4F1EA]/50 transition-colors">
                  <td class="p-6">
                    <div class="font-black text-[#1e293b] text-xs mb-1 truncate w-48 font-mono">{run.run_id}</div>
                    <div class="text-[10px] text-[#94a3b8] font-mono">{new Date(run.started_at).toLocaleString()}</div>
                  </td>
                  <td class="p-6">
                    <span class={`px-2 py-0.5 rounded-md text-[9px] font-bold uppercase tracking-widest ${run.status === 'completed' ? 'bg-[#10b981]/10 text-[#10b981]' : (run.status === 'failed' ? 'bg-[#ef4444]/10 text-[#ef4444]' : 'bg-[#3b82f6]/10 text-[#3b82f6]')}`}>
                       {run.status}
                    </span>
                  </td>
                  <td class="p-6">
                     <div class="flex gap-4 text-[11px] font-mono">
                        <div class="flex flex-col">
                           <span class="text-[8px] text-[#94a3b8] uppercase">Processed</span>
                           <span class="font-bold text-[#0f172a]">{run.processed_count}</span>
                        </div>
                        <div class="flex flex-col">
                           <span class="text-[8px] text-[#10b981] uppercase">Rec</span>
                           <span class="font-bold text-[#10b981]">{run.recorded_count}</span>
                        </div>
                        <div class="flex flex-col">
                           <span class="text-[8px] text-[#ef4444] uppercase">Err</span>
                           <span class="font-bold text-[#ef4444]">{run.error_count}</span>
                        </div>
                     </div>
                  </td>
                  <td class="p-6 text-[11px] font-mono text-[#64748b]">
                     {run.finished_at ? `${Math.round((new Date(run.finished_at).getTime() - new Date(run.started_at).getTime()) / 60000)}m ${Math.round(((new Date(run.finished_at).getTime() - new Date(run.started_at).getTime()) % 60000) / 1000)}s` : '---'}
                  </td>
                  <td class="p-6 text-right">
                     <button class="p-2 bg-white border border-[#e2e8f0] rounded-lg hover:bg-[#F4F1EA] text-[#64748b] transition-colors" title="View Logs (Coming Soon)">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
                     </button>
                  </td>
                </tr>
              ))}
              {runs.length === 0 && (
                <tr>
                   <td colspan="5" class="p-24 text-center">
                      <p class="text-[#94a3b8] font-mono text-xs uppercase tracking-[0.2em]">No discovery runs recorded yet.</p>
                   </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>

  <SovereignFooter client:visible />
</SovereignLayout>
