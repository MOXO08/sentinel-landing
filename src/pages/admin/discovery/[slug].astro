---
import SovereignLayout from '../../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../../components/react/sentinel/sovereign-footer';

export const prerender = false;

const { slug } = Astro.params;
const env = (Astro.locals as any).runtime?.env;

let audit = null as any;

try {
  if (env?.DB) {
     const result = await env.DB.prepare(`SELECT * FROM discovery_audits WHERE slug = ?`).bind(slug).first();
     audit = result;
  }
} catch (e) {
  console.error("Discovery Detail Error:", e);
}

if (!audit) {
   return Astro.redirect('/admin/discovery');
}

// Parse JSON fields
const rulesFailed = JSON.parse(audit.rules_failed || '[]');
const rulesPassed = JSON.parse(audit.rules_passed || '[]');
const detectedSignals = JSON.parse(audit.detected_signals || '[]');
const missingSignals = JSON.parse(audit.missing_signals || '[]');
const scoreBreakdown = JSON.parse(audit.score_breakdown || '{}');
const visibleGaps = JSON.parse(audit.visible_gaps || '[]');
---

<SovereignLayout title={`${audit.repo_name} | Audit Detail`}>
  <SovereignHeader client:idle />
  
  <main class="bg-[#F4F1EA] pt-32 pb-24 px-6 min-h-screen font-sans">
    <div class="max-w-5xl mx-auto">
      <!-- Breadcrumbs -->
      <nav class="flex mb-8 text-[10px] font-mono uppercase tracking-widest text-[#94a3b8] gap-2">
        <a href="/admin" class="hover:text-[#0f172a]">HQ</a>
        <span>/</span>
        <a href="/admin/discovery" class="hover:text-[#0f172a]">Discovery Inbox</a>
        <span>/</span>
        <span class="text-[#0f172a] font-bold">{audit.repo_name}</span>
      </nav>

      <div class="flex flex-col lg:flex-row gap-12">
        <!-- Main Info -->
        <div class="flex-1 space-y-8">
          <section class="bg-white rounded-3xl p-10 border border-[#e2e8f0] shadow-sm relative overflow-hidden">
             <!-- Risk Ribbon -->
             <div class={`absolute top-0 right-0 px-6 py-2 text-[10px] font-black uppercase tracking-widest ${audit.risk_level === 'Low' ? 'bg-[#10b981] text-white' : (audit.risk_level === 'Medium' ? 'bg-[#f59e0b] text-white' : 'bg-[#ef4444] text-white')}`}>
                {audit.risk_level} RISK
             </div>

             <div class="flex flex-col md:flex-row gap-8 items-start mb-10">
                <div class="w-20 h-20 bg-[#0f172a] rounded-2xl flex items-center justify-center text-white text-3xl font-black italic">
                   {audit.repo_name.charAt(0).toUpperCase()}
                </div>
                <div class="flex-1">
                   <h1 class="text-4xl font-black text-[#0f172a] mb-2 tracking-tighter uppercase italic">{audit.repo_name}</h1>
                   <div class="flex flex-wrap gap-4 items-center">
                      <a href={audit.repo_url} target="_blank" class="text-xs font-mono text-[#3b82f6] hover:underline flex items-center gap-1">
                         {audit.repo_url}
                         <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </a>
                      <span class="text-[10px] font-mono text-[#94a3b8] uppercase tracking-wider">{audit.stars} Stars • {audit.language}</span>
                      <span class="px-2 py-0.5 bg-[#f1f5f9] text-[#64748b] text-[9px] font-bold rounded uppercase">{audit.compliance_status}</span>
                   </div>
                </div>
             </div>

             <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-8 border-y border-[#f1f5f9] mb-10">
                <div class="flex flex-col">
                   <span class="text-[9px] font-mono text-[#94a3b8] uppercase tracking-widest mb-1">Audit Score</span>
                   <span class="text-2xl font-black text-[#0f172a]">{audit.audit_score}/100</span>
                </div>
                <div class="flex flex-col">
                   <span class="text-[9px] font-mono text-[#94a3b8] uppercase tracking-widest mb-1">Confidence</span>
                   <span class="text-2xl font-black text-[#0f172a] uppercase">{audit.confidence_level}</span>
                </div>
                <div class="flex flex-col">
                   <span class="text-[9px] font-mono text-[#94a3b8] uppercase tracking-widest mb-1">Status</span>
                   <span class={`text-[10px] font-black uppercase tracking-widest mt-2 ${audit.is_public ? 'text-[#10b981]' : 'text-[#f59e0b]'}`}>
                      {audit.is_public ? '● Publicly Listed' : '○ Internal Only'}
                   </span>
                </div>
                <div class="flex flex-col">
                   <span class="text-[9px] font-mono text-[#94a3b8] uppercase tracking-widest mb-1">Last Sync</span>
                   <span class="text-[11px] font-bold text-[#64748b] mt-2">{new Date(audit.updated_at).toLocaleDateString()}</span>
                </div>
             </div>

             <div class="space-y-8">
                <div>
                   <h3 class="text-[10px] font-mono font-bold text-[#0f172a] uppercase tracking-[0.2em] mb-4">Neural Assessment Summary</h3>
                   <p class="text-sm text-[#475569] leading-relaxed bg-[#f8fafc] p-6 rounded-2xl border border-[#f1f5f9]">
                      {audit.summary_text}
                   </p>
                </div>

                <div class="grid md:grid-cols-2 gap-8">
                   <div>
                      <h3 class="text-[10px] font-mono font-bold text-[#dc2626] uppercase tracking-[0.2em] mb-4">Critical Technical Gaps</h3>
                      <ul class="space-y-3">
                         {visibleGaps.map((gap: string) => (
                            <li class="flex items-start gap-2 text-xs text-[#64748b]">
                               <svg class="w-3.5 h-3.5 text-[#ef4444] mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                               {gap}
                            </li>
                         ))}
                         {visibleGaps.length === 0 && <li class="text-xs text-[#94a3b8] italic">No major technical gaps detected.</li>}
                      </ul>
                   </div>
                   <div>
                      <h3 class="text-[10px] font-mono font-bold text-[#0f172a] uppercase tracking-[0.2em] mb-4">Regulatory Artifacts</h3>
                      <div class="flex flex-wrap gap-2">
                         {rulesFailed.map((rule: string) => (
                            <span class="px-2 py-1 bg-[#1e293b]/5 text-[#1e293b] text-[10px] font-bold rounded border border-[#1e293b]/10 uppercase font-mono">
                               {rule}
                            </span>
                         ))}
                         {rulesFailed.length === 0 && <span class="text-xs text-[#94a3b8] italic">No failures recorded.</span>}
                      </div>
                   </div>
                </div>
             </div>
          </section>

          <section class="bg-white rounded-3xl p-10 border border-[#e2e8f0] shadow-sm">
             <h3 class="text-[10px] font-mono font-bold text-[#0f172a] uppercase tracking-[0.2em] mb-6">Technical Signal Analysis</h3>
             <div class="grid md:grid-cols-2 gap-12">
                <div>
                   <h4 class="text-[9px] font-mono text-[#059669] uppercase tracking-widest mb-4 flex items-center gap-2">
                       <div class="w-1.5 h-1.5 rounded-full bg-[#059669]"></div>
                       Detected Signals
                   </h4>
                   <ul class="space-y-3">
                      {detectedSignals.map((s: string) => (
                         <li class="text-[11px] font-bold text-[#475569] border-l-2 border-[#10b981] pl-3 py-1 bg-[#f0fdf4]/50">
                            {s}
                         </li>
                      ))}
                      {detectedSignals.length === 0 && <li class="text-xs text-[#94a3b8] italic">No signals identified.</li>}
                   </ul>
                </div>
                <div>
                   <h4 class="text-[9px] font-mono text-[#ef4444] uppercase tracking-widest mb-4 flex items-center gap-2">
                       <div class="w-1.5 h-1.5 rounded-full bg-[#ef4444]"></div>
                       Missing Signals
                   </h4>
                   <ul class="space-y-3">
                      {missingSignals.map((s: string) => (
                         <li class="text-[11px] font-bold text-[#475569] border-l-2 border-[#ef4444] pl-3 py-1 bg-[#fef2f2]/50">
                            {s}
                         </li>
                      ))}
                      {missingSignals.length === 0 && <li class="text-xs text-[#94a3b8] italic">All primary signals detected.</li>}
                   </ul>
                </div>
             </div>

             <div class="mt-12 pt-8 border-t border-[#f1f5f9]">
                <h4 class="text-[9px] font-mono text-[#64748b] uppercase tracking-widest mb-6">Rules Compliance</h4>
                <div class="grid md:grid-cols-2 gap-8">
                   <div>
                      <span class="text-[8px] text-[#94a3b8] uppercase block mb-3">Rules Passed</span>
                      <div class="flex flex-wrap gap-2">
                         {rulesPassed.map((r: string) => (
                            <span class="px-2 py-1 bg-[#f0fdf4] text-[#166534] text-[9px] font-mono font-bold rounded border border-[#bbf7d0] uppercase">
                               {r}
                            </span>
                         ))}
                      </div>
                   </div>
                   <div>
                      <span class="text-[8px] text-[#94a3b8] uppercase block mb-3">Rules Failed</span>
                      <div class="flex flex-wrap gap-2">
                         {rulesFailed.map((r: string) => (
                            <span class="px-2 py-1 bg-[#fef2f2] text-[#991b1b] text-[9px] font-mono font-bold rounded border border-[#fecaca] uppercase">
                               {r}
                            </span>
                         ))}
                      </div>
                   </div>
                </div>
             </div>
          </section>

          <section class="bg-[#0f172a] rounded-3xl p-10 text-white shadow-xl">
              <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-8">Score Breakdown Basis</h3>
              <div class="space-y-6 max-w-2xl font-mono text-[10px]">
                  <div class="flex justify-between items-center opacity-60">
                      <span>Baseline Capability</span>
                      <span>{scoreBreakdown.base || 100}</span>
                  </div>
                  
                  {scoreBreakdown.deductions?.map((d: any) => (
                      <div class="flex justify-between items-center text-[#f87171]">
                          <div class="flex flex-col">
                             <span class="font-black">-{d.penalty} : {d.rule}</span>
                             <span class="text-[8px] opacity-60">{d.reason}</span>
                          </div>
                          <span>FINAL</span>
                      </div>
                  ))}

                  {scoreBreakdown.bonuses?.map((b: any) => (
                      <div class="flex justify-between items-center text-[#4ade80]">
                          <div class="flex flex-col">
                             <span class="font-black">+{b.bonus} : {b.rule || 'GENERAL'}</span>
                             <span class="text-[8px] opacity-60">{b.reason}</span>
                          </div>
                          <span>BOOST</span>
                      </div>
                  ))}

                  <div class="pt-6 border-t border-white/10 flex justify-between items-end">
                      <span class="text-[14px] font-black uppercase italic tracking-tighter">Weighted Discovery Score</span>
                      <span class="text-4xl font-black italic">{audit.audit_score}</span>
                  </div>
              </div>
          </section>

          <section class="bg-white rounded-3xl p-10 border border-[#e2e8f0] shadow-sm">
             <h3 class="text-[10px] font-mono font-bold text-[#0f172a] uppercase tracking-[0.2em] mb-6">Metadata & Stack</h3>
             <div class="grid grid-cols-2 gap-8 font-mono">
                <div>
                   <span class="text-[8px] text-[#94a3b8] uppercase block mb-1">Detected AI Stack</span>
                   <div class="text-[11px] text-[#0f172a] bg-[#f8fafc] p-3 rounded-lg border border-[#f1f5f9]">
                      {audit.detected_ai_stack}
                   </div>
                </div>
                <div>
                   <span class="text-[8px] text-[#94a3b8] uppercase block mb-1">Slug Identifier</span>
                   <div class="text-[11px] text-[#0f172a] bg-[#f8fafc] p-3 rounded-lg border border-[#f1f5f9]">
                      {audit.slug}
                   </div>
                </div>
             </div>
          </section>
        </div>

        <!-- Sidebar Actions -->
        <div class="w-full lg:w-72 space-y-6">
           <div class="bg-white rounded-3xl p-8 border border-[#e2e8f0] shadow-sm">
              <h3 class="text-[10px] font-mono font-bold text-[#0f172a] uppercase tracking-[0.2em] mb-6">Governance Actions</h3>
              <div class="space-y-4">
                 <button 
                   id="publish-btn"
                   class={`w-full py-3 px-4 rounded-xl text-xs font-black uppercase tracking-widest transition-all shadow-sm ${audit.is_public ? 'bg-[#ef4444] text-white hover:bg-[#dc2626]' : 'bg-[#10b981] text-white hover:bg-[#059669]'}`}
                 >
                    {audit.is_public ? 'Hide from Hub' : 'Publish to Hub'}
                 </button>
                 <button 
                   id="rescan-btn"
                   class="w-full py-3 px-4 rounded-xl bg-white border border-[#e2e8f0] text-[#0f172a] text-xs font-black uppercase tracking-widest hover:bg-[#F4F1EA] transition-all"
                 >
                    Trigger Rescan
                 </button>
              </div>
           </div>

           <div class="bg-[#0f172a] rounded-3xl p-8 text-white">
              <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-6">Internal Logs</h3>
              <div class="space-y-4 font-mono text-[9px]">
                 <div class="flex justify-between border-b border-white/10 pb-2">
                    <span class="opacity-60 uppercase">Created</span>
                    <span>{new Date(audit.created_at || audit.scan_timestamp).toLocaleDateString()}</span>
                 </div>
                 <div class="flex justify-between border-b border-white/10 pb-2">
                    <span class="opacity-60 uppercase">ID</span>
                    <span>#{audit.id}</span>
                 </div>
                 <div class="flex justify-between">
                    <span class="opacity-60 uppercase">Context</span>
                    <span>{audit.execution_context}</span>
                 </div>
              </div>
           </div>
        </div>
      </div>
    </div>
  </main>

  <script define:vars={{ id: audit.id, is_public: !!audit.is_public, repo_url: audit.repo_url }}>
    const actionBtn = document.getElementById('publish-btn');
    const rescanBtn = document.getElementById('rescan-btn');

    actionBtn.onclick = async () => {
       const res = await fetch('/api/admin/action', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
             action: 'toggle_discovery_public', 
             payload: { id, is_public: !is_public }
          })
       });
       const data = await res.json();
       if (data.success) window.location.reload();
       else alert(data.error || 'Action failed');
    };

    rescanBtn.onclick = async () => {
       if (confirm(`Trigger manual rescan for ${repo_url}?`)) {
          const res = await fetch('/api/admin/action', {
             method: 'POST',
             headers: { 'Content-Type': 'application/json' },
             body: JSON.stringify({ 
                action: 'rescan_discovery', 
                payload: { repo_url }
             })
          });
          const data = await res.json();
          alert(data.message || 'Rescan request queued.');
       }
    };
  </script>

  <SovereignFooter client:visible />
</SovereignLayout>
