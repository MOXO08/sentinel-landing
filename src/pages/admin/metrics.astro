---
import SovereignLayout from '../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../components/react/sentinel/sovereign-footer';

export const prerender = false;

const env = (Astro.locals as any).runtime?.env;

let metrics = {
  total: 0,
  clients: 0,
  projects: 0,
  recentLogs: []
};

try {
  if (env?.DB) {
    // Aggregate Metrics
    const stats = await env.DB.prepare(`
      SELECT 
        COUNT(*) AS total, 
        COUNT(DISTINCT anonymous_client_id) AS clients,
        COUNT(DISTINCT project_hash) AS projects
      FROM audit_logs
    `).first();
    
    if (stats) {
      metrics.total = stats.total;
      metrics.clients = stats.clients;
      metrics.projects = stats.projects;
    }

    // Recent Activity
    metrics.recentLogs = await env.DB.prepare(`
      SELECT 
        app_name, 
        cli_version, 
        status, 
        created_at,
        substr(anonymous_client_id, 1, 8) as client_prefix,
        substr(project_hash, 1, 8) as project_prefix
      FROM audit_logs
      ORDER BY created_at DESC
      LIMIT 10
    `).all();
  }
} catch (e) {
  console.error("Dashboard Error:", e);
}
---

<SovereignLayout title="Sentinel Internal | System Metrics">
  <SovereignHeader client:idle />
  
  <main class="bg-[#F4F1EA] pt-32 pb-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12">
        <h1 class="text-4xl font-black text-[#0f172a] mb-2 tracking-tight">Internal Infrastructure Metrics</h1>
        <p class="text-[#64748b] font-mono text-sm uppercase tracking-widest">Confidential / System Health</p>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="bg-white p-8 rounded-2xl border border-[#e2e8f0] shadow-sm">
          <p class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-[0.2em] mb-4">Total Audits</p>
          <div class="text-5xl font-black text-[#0f172a]">{metrics.total}</div>
        </div>
        <div class="bg-white p-8 rounded-2xl border border-[#e2e8f0] shadow-sm">
          <p class="text-[10px] font-mono font-bold text-[#3b82f6] uppercase tracking-[0.2em] mb-4">Unique Clients</p>
          <div class="text-5xl font-black text-[#0f172a]">{metrics.clients}</div>
        </div>
        <div class="bg-white p-8 rounded-2xl border border-[#e2e8f0] shadow-sm">
          <p class="text-[10px] font-mono font-bold text-[#10b981] uppercase tracking-[0.2em] mb-4">Unique Projects</p>
          <div class="text-5xl font-black text-[#0f172a]">{metrics.projects}</div>
        </div>
      </div>

      <!-- Recent Logs Table -->
      <div class="bg-white rounded-2xl border border-[#e2e8f0] overflow-hidden shadow-sm">
        <div class="p-6 border-b border-[#e2e8f0] bg-[#f8fafc]">
          <h2 class="text-sm font-bold text-[#0f172a] uppercase tracking-wider">Live Audit Stream (Last 10)</h2>
        </div>
        <table class="w-full text-left text-sm border-collapse">
          <thead class="bg-[#f8fafc] text-[#64748b] font-mono text-[10px] uppercase tracking-widest border-b border-[#e2e8f0]">
            <tr>
              <th class="p-4">App Name</th>
              <th class="p-4">CLI Ver</th>
              <th class="p-4">Status</th>
              <th class="p-4">Client</th>
              <th class="p-4">Project</th>
              <th class="p-4">Timestamp</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#e2e8f0] font-mono text-[11px]">
            {metrics.recentLogs.results?.map((log) => (
              <tr class="hover:bg-[#f8fafc] transition-colors">
                <td class="p-4 text-[#0f172a] font-bold">{log.app_name}</td>
                <td class="p-4">{log.cli_version || 'N/A'}</td>
                <td class="p-4">
                  <span class={`px-2 py-0.5 rounded-full text-[9px] font-bold ${log.status === 'COMPLIANT' ? 'bg-[#10b981]/10 text-[#059669]' : 'bg-[#ef4444]/10 text-[#dc2626]'}`}>
                    {log.status}
                  </span>
                </td>
                <td class="p-4 text-[#64748b]">{log.client_prefix}...</td>
                <td class="p-4 text-[#64748b]">{log.project_prefix}...</td>
                <td class="p-4 text-[#94a3b8]">{log.created_at}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-8 p-6 bg-[#0f172a] rounded-xl text-white">
        <h3 class="text-xs font-bold uppercase tracking-widest mb-4 opacity-70">Direct SQL Verification Queries</h3>
        <pre class="bg-black/30 p-4 rounded-lg font-mono text-[11px] text-[#10b981] overflow-x-auto">
-- Total Audits
SELECT COUNT(*) FROM audit_logs;

-- Unique Clients
SELECT COUNT(DISTINCT anonymous_client_id) FROM audit_logs;

-- Unique Projects
SELECT COUNT(DISTINCT project_hash) FROM audit_logs;
        </pre>
      </div>
    </div>
  </main>

  <SovereignFooter client:visible />
</SovereignLayout>
