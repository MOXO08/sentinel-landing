---
import SovereignLayout from '../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../components/react/sentinel/sovereign-footer';
import { SaasPage } from '../../components/react/sentinel/saas-page';
import { BottomCTA } from '../../components/react/sentinel/BottomCTA';

export const prerender = false;

const seoTitle = "Sentinel for SaaS — EU AI Act Compliance for AI-Powered Platforms";
const seoDescription = "Multi-tenant AI audit isolation for SaaS companies. Downstream provider obligations, AI feature compliance at scale, and per-customer audit trail generation.";

const schema = {"@context":"https://schema.org","@type":"WebPage","name":"Sentinel for SaaS","description":"EU AI Act compliance for SaaS platforms with AI features. Multi-tenant audit isolation, downstream provider obligations, and AI feature compliance at scale.","url":"https://gettingsentinel.com/use-cases/saas","publisher":{"@type":"Organization","name":"Sentinel"}};
---

<SovereignLayout title={seoTitle} description={seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <SovereignHeader client:load />
  
  <main class="bg-[#F4F1EA]">
    <SaasPage client:load />
  </main>

  <BottomCTA client:visible />
  <SovereignFooter client:idle />
</SovereignLayout>

