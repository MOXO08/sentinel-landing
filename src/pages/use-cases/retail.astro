---
import SovereignLayout from '../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../components/react/sentinel/sovereign-footer';
import { RetailPage } from '../../components/react/sentinel/retail-page';
import { BottomCTA } from '../../components/react/sentinel/BottomCTA';

export const prerender = false;

const seoTitle = "Sentinel for Retail — EU AI Act Compliance for Recommendation & Profiling AI";
const seoDescription = "Audit recommendation engines, dynamic pricing AI, and customer profiling systems for EU AI Act compliance. Cryptographic evidence for retail AI transparency obligations.";

const schema = {"@context":"https://schema.org","@type":"WebPage","name":"Sentinel for Retail","description":"EU AI Act compliance for retail AI: recommendation engines, dynamic pricing, customer profiling, and inventory forecasting audit trails.","url":"https://gettingsentinel.com/use-cases/retail","publisher":{"@type":"Organization","name":"Sentinel"}};
---

<SovereignLayout title={seoTitle} description={seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <SovereignHeader client:load />
  
  <main class="bg-[#F4F1EA]">
    <RetailPage client:load />
  </main>

  <BottomCTA client:visible />
  <SovereignFooter client:idle />
</SovereignLayout>

