---
import SovereignLayout from '../../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../../components/react/sentinel/sovereign-footer';
export const prerender = true;
---

<SovereignLayout title="Privacy Policy | Sentinel Infrastructure" description="Enterprise data protection and privacy policy for the Sentinel Audit API.">
  <SovereignHeader client:load />

  <main class="bg-[#F4F1EA] py-32">
    <div class="max-w-screen-md mx-auto px-6">
      <div class="text-[10px] font-mono font-bold text-[#10b981] uppercase tracking-[0.2em] mb-4">Governance</div>
      <h1 class="text-4xl md:text-5xl font-bold text-[#0f172a] mb-12 border-b border-[#cbd5e1] pb-10 tracking-tight">Privacy Policy</h1>
      
      <div class="prose prose-slate prose-sm max-w-none prose-headings:text-[#0f172a] prose-p:text-[#475569] prose-p:font-light prose-strong:text-[#0f172a] space-y-12">
        <section>
          <h2 class="text-xl font-bold mb-4">01. Data Minimization</h2>
          <p>
            Sentinel is designed with a "Privacy by Design" architecture. Our WASM-based scan engine executes within your local browser sandbox. No source code or model weights are ever transmitted to our servers.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold mb-4">02. Information Collection</h2>
          <p>
            We collect only the information necessary to provide our industrial compliance services:
          </p>
          <ul class="list-disc pl-6 space-y-2 mt-4 text-[#475569] font-light">
            <li><strong>Lead Generation:</strong> Corporate email, company name, and role provided during the Proforma request process.</li>
            <li><strong>Telemetry:</strong> Anonymous usage metrics (audit counts, regional distribution) are stored to verify system integrity.</li>
            <li><strong>Service Data:</strong> Audit verdicts and metadata for technical files are stored in our secure D1 edge ledger.</li>
          </ul>
        </section>

        <section>
          <h2 class="text-xl font-bold mb-4">03. Data Security</h2>
          <p>
            All data is encrypted in transit via TLS and stored in Cloudflare's secure infrastructure. We do not sell or share your data with third-party advertisers. 
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold mb-4">04. Compliance with EU AI Act</h2>
          <p>
            Sentinel's logging protocols are aligned with the traceability requirements of Article 12 of the EU AI Act (Regulation EU 2024/1689).
          </p>
        </section>
      </div>

      <div class="mt-20 pt-10 border-t border-[#cbd5e1]">
        <a href="/" class="text-[#10b981] hover:text-[#0f172a] font-bold transition-colors inline-flex items-center gap-2">
          ← Return Home
        </a>
      </div>
    </div>
  </main>

  <SovereignFooter client:idle />
</SovereignLayout>
