---
import SovereignLayout from '../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../components/react/sentinel/sovereign-footer';
import { OnboardingPage } from '../components/react/sentinel/onboarding-page';

export const prerender = false;
---

<SovereignLayout title="Sentinel Onboarding — Welcome to the Audit Infrastructure" description="Get started with Sentinel: download your implementation guide, integrate the API, and generate your first legally-defensible EU AI Act compliance proof.">
  <SovereignHeader client:load />
  
  <main class="bg-[#F4F1EA]">
    <OnboardingPage client:load />
  </main>

  <SovereignFooter client:idle />
</SovereignLayout>

