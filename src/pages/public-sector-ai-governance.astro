---
import SovereignLayout from '../layouts/SovereignLayout.astro';
import { SovereignHeader } from '../components/react/sentinel/sovereign-header';
import { SovereignFooter } from '../components/react/sentinel/sovereign-footer';

const seoTitle = "Public Sector AI Governance | EU AI Act | Sentinel";
const seoDescription = "Sovereign AI governance for the public sector. Ensure transparency, accountability, and compliance for governmental AI deployments.";
---

<SovereignLayout title={seoTitle} description={seoDescription}>
  <SovereignHeader client:load activePage="/public-sector-ai-governance" />
  
  <main class="bg-[#F4F1EA] pt-32 pb-24 text-[#0f172a]">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-4xl md:text-6xl font-black italic uppercase tracking-tighter mb-8">
        Public Sector <span class="text-[#10b981]">AI</span> Governance
      </h1>
      <p class="text-xl text-[#475569] leading-relaxed mb-12 font-light">
        Building trust through algorithmic transparency. Sentinel enables public institutions to deploy AI as a force for good, backed by immutable audit trails.
      </p>
      
      <div class="grid md:grid-cols-2 gap-8 mb-16">
        <div class="bg-white p-8 rounded-2xl border border-[#cbd5e1] shadow-sm">
          <h3 class="text-lg font-bold mb-4">Transparency Art. 13</h3>
          <p class="text-sm text-[#64748b] leading-relaxed">Automated disclosure mechanisms to fulfill public transparency mandates for AI interaction.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl border border-[#cbd5e1] shadow-sm">
          <h3 class="text-lg font-bold mb-4">Fundamental Rights</h3>
          <p class="text-sm text-[#64748b] leading-relaxed">Integrated impact assessments to ensure AI deployments respect fundamental EU rights and values.</p>
        </div>
      </div>
    </div>
  </main>

  <SovereignFooter client:idle />
</SovereignLayout>
