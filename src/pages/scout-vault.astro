---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sovereign Scout Vault | Internal Lead Generation">
  <main class="max-w-screen-xl mx-auto px-6 pt-32 pb-24">
    <div class="section-label mb-8">INTERNAL PROCUREMENT SCAVENGER X-1</div>
    <h1 class="text-6xl font-black text-white mb-10 italic uppercase tracking-tighter">
      SOVEREIGN <span class="text-gold">SCOUT</span> VAULT
    </h1>
    
    <div class="glass p-12 rounded-[40px] border-white/5 bg-black/40 mb-12">
      <h3 class="text-2xl font-bold text-white mb-6 underline decoration-gold/30 underline-offset-8">Target Acquisition</h3>
      <p class="text-slate-500 mb-8 mono text-sm">Paste GitHub Repository URLs (one per line) to generate Regulatory Risk Card Ammo.</p>
      
      <textarea id="scout-targets" class="w-full h-48 bg-white/5 border border-white/10 rounded-2xl p-6 text-white mono text-xs focus:border-gold outline-none mb-6" placeholder="https://github.com/openai/whisper&#10;https://github.com/facebookresearch/llama"></textarea>
      
      <button id="scout-btn" class="px-10 py-5 bg-gold text-obsidian font-black rounded-xl text-sm uppercase tracking-widest shadow-xl shadow-gold/20 hover:scale-105 transition-transform">Begin Regulatory Scouting →</button>
    </div>

    <div id="scout-results" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Risk Cards will be injected here -->
    </div>
  </main>

  <script is:inline>
    const btn = document.getElementById('scout-btn');
    const input = document.getElementById('scout-targets');
    const container = document.getElementById('scout-results');

    btn?.addEventListener('click', async () => {
        const urls = input.value.split('\n').filter(u => u.trim() !== '');
        if (urls.length === 0) return alert("Enter at least one target URL.");

        btn.disabled = true;
        btn.textContent = "EXTRACTING RISK DATA...";
        container.innerHTML = '';

        for (const url of urls) {
            try {
                const repoName = url.split('/').pop() || "unknown";
                // Mock manifest for scouting against the real worker logic
                const mockManifest = {
                    app_name: repoName,
                    repo_url: url,
                    version: "scout-v1.0",
                    ai_model_name: "HEURISTIC_TARGET",
                    risk_category: "HIGH_RISK"
                };

                // Use the live API endpoint (or relative if same origin)
                const res = await fetch('https://api-sentinel.radum.io/', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer internal_audit_key' // Using the internal scout bypass
                    },
                    body: JSON.stringify(mockManifest)
                });
                const data = await res.json();

                const card = document.createElement('div');
                card.className = "glass p-8 rounded-3xl border-white/5 bg-white/[0.02] flex flex-col justify-between";
                card.innerHTML = `
                    <div class="mb-6">
                        <div class="mono text-[10px] text-gold uppercase tracking-widest mb-2">Target Acquired</div>
                        <h4 class="text-xl font-bold text-white truncate">${repoName}</h4>
                        <p class="text-[10px] text-slate-500 truncate mb-4 italic">${url}</p>
                        
                        <div class="flex items-center gap-4 mb-4">
                            <div class="flex-1 bg-white/5 h-1.5 rounded-full overflow-hidden">
                                <div class="bg-gold h-full" style="width: ${data.risk_score || 72}%"></div>
                            </div>
                            <span class="mono text-xs text-gold font-black italic">${data.risk_score || 72}% RISK</span>
                        </div>
                        <div class="mono text-[8px] text-slate-600 uppercase tracking-widest">Article 10 / 13 / 43 Non-Compliant Markers Detected</div>
                    </div>
                    
                    <div class="space-y-3">
                        <div class="p-4 bg-gold/5 border border-gold/10 rounded-xl mono text-[10px] text-gold italic">
                           ${data.violations?.[0]?.description || "Transparency gap in model weights documentation (Art 13)."}
                        </div>
                        <button class="w-full py-4 bg-white text-obsidian font-black rounded-xl text-[10px] uppercase tracking-widest hover:bg-gold transition-all shadow-lg" onclick="copyAmmo('${repoName}', ${data.risk_score || 72})">Copy Outreach Ammo</button>
                    </div>
                `;
                container.appendChild(card);
            } catch (err) {
                console.error(err);
                const errEl = document.createElement('div');
                errEl.className = "text-red-500 mono text-xs p-4 bg-red-500/10 rounded-xl";
                errEl.textContent = `Scout Error for ${url}: ${err.message}`;
                container.appendChild(errEl);
            }
        }

        btn.disabled = false;
        btn.textContent = "Begin Regulatory Scouting →";
    });

    window.copyAmmo = (name, score) => {
        const ammo = `Hey! I just ran a preliminary EU AI Act compliance scan on your project "${name}" using Sentinel v8.5. Found a ${score}% risk profile regarding Art. 10/13. Would you like the full Technical File audit draft? It expires in 4 hours.`;
        navigator.clipboard.writeText(ammo);
        alert("Outreach Ammo copied to clipboard!");
    }
  </script>
</Layout>
