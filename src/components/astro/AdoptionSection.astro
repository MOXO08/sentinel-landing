---
interface Props {
  totalAudits: number;
  uniqueClients: number;
  uniqueProjects: number;
}

const { totalAudits, uniqueClients, uniqueProjects } = Astro.props;
---

<section id="adoption" class="bg-[#F4F1EA] py-24 border-t border-[#c5832b]/10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-black text-[#0f172a] mb-6 tracking-tight">Trusted by developers building compliant AI</h2>
      <p class="text-lg text-[#475569] max-w-2xl mx-auto font-light">
        Sentinel integrates directly into modern development workflows and CI pipelines.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {/* Metric 1: Total Scans */}
      <div class="bg-white p-8 rounded-3xl border border-[#e2e8f0] hover:border-[#cbd5e1] transition-all shadow-sm hover:shadow-md flex flex-col items-center text-center group">
        <div class="w-12 h-12 rounded-xl bg-[#F4F1EA] flex items-center justify-center mb-6 border border-[#e2e8f0] group-hover:border-[#c5832b]/30">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#c5832b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
        </div>
        <h4 class="font-bold text-[#0f172a] mb-1">Total scans executed</h4>
        <div class="text-5xl font-black text-[#0f172a] mb-2">{totalAudits.toLocaleString()}</div>
        <p class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-widest">Global audit volume</p>
      </div>

      {/* Metric 2: Unique Projects */}
      <div class="bg-white p-8 rounded-3xl border border-[#e2e8f0] hover:border-[#cbd5e1] transition-all shadow-sm hover:shadow-md flex flex-col items-center text-center group">
        <div class="w-12 h-12 rounded-xl bg-[#F4F1EA] flex items-center justify-center mb-6 border border-[#e2e8f0] group-hover:border-[#3b82f6]/30">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-folder-root"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/><circle cx="12" cy="13" r="2"/></svg>
        </div>
        <h4 class="font-bold text-[#0f172a] mb-1">Unique repositories</h4>
        <div class="text-5xl font-black text-[#0f172a] mb-2">{uniqueProjects.toLocaleString()}</div>
        <p class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-widest">Verified Al Systems</p>
      </div>

      {/* Metric 3: Unique Clients */}
      <div class="bg-white p-8 rounded-3xl border border-[#e2e8f0] hover:border-[#cbd5e1] transition-all shadow-sm hover:shadow-md flex flex-col items-center text-center group">
        <div class="w-12 h-12 rounded-xl bg-[#F4F1EA] flex items-center justify-center mb-6 border border-[#e2e8f0] group-hover:border-[#10b981]/30">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-terminal"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>
        </div>
        <h4 class="font-bold text-[#0f172a] mb-1">Unique environments</h4>
        <div class="text-5xl font-black text-[#0f172a] mb-2">{uniqueClients.toLocaleString()}</div>
        <p class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-widest">Active CLI Installations</p>
      </div>
    </div>
  </div>
</section>
