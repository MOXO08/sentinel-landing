---
interface Props {
  totalAudits: number;
}

const { totalAudits } = Astro.props;
---

<section id="adoption" class="bg-[#F4F1EA] py-24 border-t border-[#c5832b]/10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-black text-[#0f172a] mb-6 tracking-tight">Trusted by developers building compliant AI</h2>
      <p class="text-lg text-[#475569] max-w-2xl mx-auto font-light">
        Sentinel integrates directly into modern development workflows and CI pipelines.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {/* Card 1: GitHub */}
      <div class="bg-white p-8 rounded-3xl border border-[#e2e8f0] hover:border-[#cbd5e1] transition-all shadow-sm hover:shadow-md flex flex-col items-center text-center group">
        <div class="w-12 h-12 rounded-xl bg-[#0f172a] flex items-center justify-center mb-6 group-hover:bg-[#c5832b] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F4F1EA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </div>
        <h4 class="font-bold text-[#0f172a] mb-4">GitHub</h4>
        <div class="space-y-3 w-full">
          <div class="text-xs font-mono bg-[#F4F1EA] px-3 py-2 rounded-lg border border-[#e2e8f0]">
             <span class="text-[#64748b]">Public repository</span>
          </div>
          <div class="text-xs font-mono bg-[#F4F1EA] px-3 py-2 rounded-lg border border-[#e2e8f0]">
             <span class="text-[#64748b]">Open source distribution</span>
          </div>
        </div>
      </div>

      {/* Card 2: NPM */}
      <div class="bg-white p-8 rounded-3xl border border-[#e2e8f0] hover:border-[#cbd5e1] transition-all shadow-sm hover:shadow-md flex flex-col items-center text-center group">
        <div class="w-12 h-12 rounded-xl bg-[#0f172a] flex items-center justify-center mb-6 group-hover:bg-[#CB3837] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F4F1EA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-package"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
        </div>
        <h4 class="font-bold text-[#0f172a] mb-4">npm</h4>
        <div class="space-y-3 w-full">
          <div class="text-xs font-mono bg-[#F4F1EA] px-3 py-2 rounded-lg border border-[#e2e8f0]">
             <span class="text-[#64748b]">Public package</span>
          </div>
          <div class="text-[10px] font-mono font-bold text-[#c5832b] uppercase tracking-widest mt-2">Version v1.x</div>
        </div>
      </div>

      {/* Card 3: Audits */}
      <div class="bg-white p-8 rounded-3xl border border-[#e2e8f0] hover:border-[#cbd5e1] transition-all shadow-sm hover:shadow-md flex flex-col items-center text-center group">
        <div class="w-12 h-12 rounded-xl bg-[#F4F1EA] flex items-center justify-center mb-6 border border-[#e2e8f0] group-hover:border-[#c5832b]/30">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#c5832b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
        </div>
        <h4 class="font-bold text-[#0f172a] mb-1">Deterministic scans executed</h4>
        <div class="text-4xl font-black text-[#0f172a] mb-2">{totalAudits.toLocaleString()}</div>
        <p class="text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-widest">Live audit activity</p>
      </div>

      {/* Card 4: Ecosystem */}
      <div class="bg-white p-8 rounded-3xl border border-[#e2e8f0] hover:border-[#cbd5e1] transition-all shadow-sm hover:shadow-md flex flex-col items-center text-center group">
        <div class="w-12 h-12 rounded-xl bg-[#F4F1EA] flex items-center justify-center mb-6 border border-[#e2e8f0] group-hover:border-[#c5832b]/30">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0f172a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layers"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.1 6.27a2 2 0 0 0 0 3.66l9.07 4.09a2 2 0 0 0 1.66 0l9.07-4.09a2 2 0 0 0 0-3.66z"/><path d="m2.1 14.07 9.07 4.09a2 2 0 0 0 1.66 0l9.07-4.09"/><path d="m2.1 10.17 9.07 4.09a2 2 0 0 0 1.66 0l9.07-4.09"/></svg>
        </div>
        <h4 class="font-bold text-[#0f172a] mb-4">Integrations</h4>
        <ul class="text-xs space-y-2 text-[#475569] font-mono text-left w-full">
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-[#c5832b]"></span> GitHub Actions
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-[#c5832b]"></span> Sentinel CLI
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-[#c5832b]"></span> CI Templates
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-[#c5832b]"></span> Starter Kits
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
