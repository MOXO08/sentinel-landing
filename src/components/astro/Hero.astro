---
import { Shield, ArrowRight, ArrowUpRight } from "lucide-react";
import LiveStats from '../react/sentinel/LiveStats';

interface Props {
  totalAudits: number;
}

const { totalAudits } = Astro.props;
---

<section class="relative max-w-7xl mx-auto px-6 pt-32 pb-24 overflow-hidden">
  {/* Light theme glow effects */}
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 bg-[radial-gradient(ellipse_800px_600px_at_50%_-20%,rgba(197,131,43,0.15),transparent)] pointer-events-none"></div>
  <div class="absolute top-0 right-0 w-[800px] h-[800px] -z-10 bg-[radial-gradient(ellipse_at_center,rgba(15,23,42,0.05),transparent_50%)] pointer-events-none"></div>

  <div class="text-center max-w-4xl mx-auto animate-in fade-in slide-in-from-bottom-5 duration-700">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[#c5832b]/30 bg-[#c5832b]/10 mb-8 backdrop-blur-md">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#c5832b] opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-[#c5832b]"></span>
      </span>
      <span class="text-[10px] font-mono text-[#b87333] font-bold uppercase tracking-[0.2em]">Sovereign Compliance Active</span>
    </div>

    <h1 class="text-5xl md:text-7xl lg:text-8xl font-black text-[#0f172a] tracking-tight mb-8 leading-[1.05]">
      Technical Evidence <br /><span class="text-[#c5832b] drop-shadow-[0_0_30px_rgba(197,131,43,0.1)]">for AI Regulatory Mapping</span>
    </h1>

    <p class="text-xl md:text-2xl text-[#475569] mb-12 leading-relaxed font-light">
      Sentinel provides the engineering infrastructure to discover, verify, and document AI system technicalities against regulatory patterns. From local AST discovery to immutable governance logs.
    </p>

    {/* CLI Command Block */}
    <div class="max-w-2xl mx-auto mb-12 group">
      <div class="relative bg-[#0f172a] rounded-2xl p-6 shadow-2xl border border-[#c5832b]/30 overflow-hidden">
        <div class="absolute top-0 right-0 p-4">
          <button id="copy-cmd" type="button" aria-label="Copy Sentinel command" class="p-2 rounded-lg bg-white/5 hover:bg-white/10 text-[#c5832b] transition-colors" title="Copy to clipboard">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-copy"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          </button>
        </div>
        <div class="flex items-center gap-4 text-left">
          <div class="flex-shrink-0 w-3 h-3 rounded-full bg-[#ef4444]"></div>
          <div class="flex-shrink-0 w-3 h-3 rounded-full bg-[#fbbf24]"></div>
          <div class="flex-shrink-0 w-3 h-3 rounded-full bg-[#22c55e]"></div>
          <span class="ml-2 font-mono text-xs text-[#64748b]">bash — 80x24</span>
        </div>
        <div class="mt-4 font-mono text-lg md:text-xl text-white text-left flex items-center gap-3">
          <span class="text-[#c5832b]">$</span>
          <code id="cli-cmd">npx @radu_api/sentinel-scan ./manifest.json</code>
        </div>
      </div>
      <p class="mt-3 text-sm text-[#64748b] font-light">
        Sentinel scans AI systems, verifies regulatory requirements, and generates technical evidence required for compliance audits.
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="#quickstart" class="w-full sm:w-auto inline-flex justify-center items-center gap-2 px-8 py-4 bg-[#0f172a] text-[#F4F1EA] font-bold rounded-xl hover:bg-[#c5832b] transition-all shadow-xl hover:shadow-[#c5832b]/20 hover:-translate-y-1">
        Run your first audit <ArrowRight className="w-4 h-4" />
      </a>
      <a href="https://github.com/MOXO08/sentinel" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto inline-flex justify-center items-center gap-2 px-8 py-4 bg-white border border-[#e2e8f0] text-[#475569] font-bold rounded-xl hover:bg-white/80 transition-all shadow-sm">
        View on GitHub <ArrowUpRight className="w-4 h-4" />
      </a>
    </div>

    {/* Social Proof Badges */}
      <div class="px-3 py-1 bg-[#F4F1EA] border border-[#e2e8f0] rounded-lg text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-widest">
        Open Source
      </div>
      <div class="px-3 py-1 bg-[#F4F1EA] border border-[#e2e8f0] rounded-lg text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-widest">
        NPM Package
      </div>
      <div class="px-3 py-1 bg-[#F4F1EA] border border-[#e2e8f0] rounded-lg text-[10px] font-mono font-bold text-[#64748b] uppercase tracking-widest">
        GitHub Action
      </div>
  </div>

    <script>
      (function() {
        const copyBtn = document.getElementById('copy-cmd');
        const cmdText = document.getElementById('cli-cmd')?.textContent?.trim();
        
        if (copyBtn && cmdText) {
          copyBtn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(cmdText);
              copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check"><polyline points="20 6 9 17 4 12"/></svg>';
              setTimeout(() => {
                copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-copy"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
              }, 2000);
            } catch {}
          });
        }
      })();
    </script>

</section>

<style>
  .animate-in {
    animation-fill-mode: both;
  }
</style>
