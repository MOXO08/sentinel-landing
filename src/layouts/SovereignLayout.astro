---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Sentinel provides deterministic AI compliance infrastructure for CI/CD. Scan AI systems locally, enforce compliance in pipelines, and generate audit-ready evidence."
} = Astro.props;

// Detect US traffic via Cloudflare Proxy
const country = Astro.request.headers.get('cf-ipcountry') || 'XX';
const isUS = country === 'US';
const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Sentinel",
  "url": "https://gettingsentinel.com",
  "logo": "https://gettingsentinel.com/favicon.svg"
};
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Favicon & Mobile Assets -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Google Analytics: Delayed for performance -->
    <script is:inline>
      window.addEventListener('load', () => {
        const script = document.createElement('script');
        script.src = 'https://www.googletagmanager.com/gtag/js?id=G-F96PE9597P';
        script.async = true;
        document.head.appendChild(script);
        
        script.onload = () => {
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-F96PE9597P', { 'page_path': window.location.pathname });
        };
      });
    </script>

    <!-- Open Graph -->
    <meta property="og:site_name" content="Sentinel" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="https://gettingsentinel.com/images/og-main.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Google Fonts: Outfit (UI) + JetBrains Mono (DATA) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    
    <!-- JSON-LD Scripts -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

    <!-- Lemon Squeezy Script -->
    <script src="https://assets.lemonsqueezy.com/lemon.js" defer></script>
    <script is:inline>
      window.createLemonSqueezy = function() {
        if (window.LemonSqueezy) {
          window.LemonSqueezy.Setup({
            eventHandler: (data) => {
              if (data.event === 'Checkout.Success') {
                // Success action
              }
            }
          });
        }
      };
      
      window.createLemonSqueezy();
      window.addEventListener('load', window.createLemonSqueezy);
    </script>
  </head>
  <body class="bg-background text-foreground antialiased overflow-x-hidden selection:bg-[#10b981]/20">
    {isUS && (
      <div class="bg-emerald-500/10 backdrop-blur-md border-b border-emerald-500/20 text-center py-3 px-4 relative z-[9000]">
        <div class="max-w-4xl mx-auto flex items-center justify-center gap-2">
          <span class="text-lg">🦅</span>
          <span class="text-sm font-medium text-[#10b981] tracking-wide">
            Exporting AI to Europe? <a href="/wiki/us-companies" class="text-[#0f172a] hover:text-[#10b981] underline decoration-[#10b981]/40 underline-offset-4 transition-colors font-semibold ml-2">Ensure EU AI Act Compliance in minutes →</a>
          </span>
        </div>
      </div>
    )}

    <slot />

    <!-- Sovereign Cookie Consent Banner -->
    <div id="cookie-banner" class="hidden fixed bottom-6 left-6 right-6 md:left-auto md:right-8 md:w-[400px] bg-[#0f172a] border border-white/10 p-6 rounded-2xl shadow-2xl z-[9999] backdrop-blur-xl">
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 rounded-full bg-[#10b981]/10 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
        </div>
        <div>
          <h4 class="text-white font-bold text-sm mb-2">Sovereign Privacy Control</h4>
          <p class="text-[#94a3b8] text-xs leading-relaxed mb-4">
            Sentinel uses essential technical cookies to maintain your secure session and audit integrity. No third-party data egression is active.
          </p>
          <div class="flex items-center gap-4">
            <button id="accept-cookies" class="px-5 py-2 bg-[#10b981] text-[#0f172a] font-bold text-xs rounded-lg hover:bg-[#059669] transition-all hover:scale-[1.02] active:scale-[0.98]">
              Acknowledge
            </button>
            <a href="/legal/privacy" class="text-[#64748b] hover:text-white text-xs font-medium transition-colors border-b border-transparent hover:border-white/20 pb-0.5">
              Legal Policy
            </a>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      (function() {
        const init = () => {
          const banner = document.getElementById('cookie-banner');
          const acceptBtn = document.getElementById('accept-cookies');
          
          if (banner && acceptBtn && !localStorage.getItem('sentinel_consent_v1')) {
            banner.classList.remove('hidden');
            banner.classList.add('animate-in', 'fade-in', 'slide-in-from-bottom-5', 'duration-500');
            acceptBtn.addEventListener('click', () => {
              localStorage.setItem('sentinel_consent_v1', 'true');
              banner.classList.add('animate-out', 'fade-out', 'slide-out-to-bottom-5', 'duration-300');
              setTimeout(() => banner.classList.add('hidden'), 300);
            });
          }
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }

        // Global Bulletproof Contact Handler (Outside of any wrappers for maximum resilience)
        document.addEventListener('click', (e) => {
          const link = e.target.closest('[data-contact-link]');
          if (link) {
            const email = link.getAttribute('data-contact-link');
            
            // 1. Trigger the mailto action explicitly
            if (email) window.location.href = `mailto:${email}`;

            // 2. Copy to clipboard
            if (navigator.clipboard && email) {
              navigator.clipboard.writeText(email).catch(() => {});
            }

            // 2. Visual Feedback
            const originalHTML = link.innerHTML;
            const isHeroButton = link.classList.contains('px-6');
            
            if (isHeroButton) {
               link.style.borderColor = '#10b981';
               link.style.color = '#10b981';
               link.innerHTML = '<span>Email Copied!</span>';
               // Force color for children
               const span = link.querySelector('span');
               if (span) span.style.color = '#10b981';
            } else {
               link.style.color = '#10b981';
            }
            
            setTimeout(() => {
              link.style.borderColor = '';
              link.style.color = '';
              link.innerHTML = originalHTML;
            }, 2000);
          }
        }, true); // Use capture phase to ensure we hit it before any preventDefault
      })();
    </script>
  </body>
</html>
